# ============================================
# FlowOps — Variáveis de Ambiente (TEMPLATE)
# ============================================
# COMO USAR EM DEV LOCAL:
#   1. Copia este arquivo para  backend/.env
#   2. Preenche os valores reais (NUNCA commita o .env preenchido)
#
# EM PRODUÇÃO (Railway):
#   Não usa este arquivo — todas as vars são definidas no painel do
#   Railway: Settings → Variables.
# ============================================

# ---- Banco de dados ----
# Em DEV: Postgres local via docker-compose (docker compose up -d db)
# Em PROD: Railway injeta DATABASE_URL automaticamente quando o
# Postgres da Railway é vinculado ao serviço.
DATABASE_URL=postgresql://flowops:flowops@localhost:5432/flowops

# ---- Autenticação ----
# Gere uma string aleatória com 64+ chars (ex: openssl rand -hex 32)
JWT_SECRET=troque-este-valor-em-producao-use-64-chars-aleatorios
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=7d

# ---- WordPress / WooCommerce — MySQL direto (opcional) ----
# Usado pra reconciliação e consultas avançadas. Só funciona se
# o MySQL aceitar conexão remota da IP do Railway.
WP_DB_HOST=
WP_DB_PORT=3306
WP_DB_USER=
WP_DB_PASSWORD=
WP_DB_DATABASE=

# ---- WooCommerce REST API ----
# Gere em: WP Admin → WooCommerce → Ajustes → Avançado → API REST
WC_URL=https://seusite.com.br
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_WEBHOOK_SECRET=troque-este-valor-webhook-hmac

# ---- ERP gigasistemas21 (MySQL, somente leitura) ----
ERP_HOST=mysql.gigasistemas.com.br
ERP_PORT=3306
ERP_USER=
ERP_PASSWORD=
ERP_DATABASE=gigasistemas21

# ---- FlowOps Bridge no WordPress (plugin flowops-abandoned-carts) ----
FLOWOPS_WP_BASE=https://seusite.com.br/wp-json
FLOWOPS_WP_KEY=cole-aqui-a-mesma-chave-do-arquivo-php

# ---- Aplicação ----
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# URL pública do frontend — usada pra travar CORS em produção.
# Aceita múltiplas separadas por vírgula:
#   FRONTEND_URL=https://flowops.vercel.app,https://flowops.lurds.com.br
FRONTEND_URL=http://localhost:3000

# ============================================
# Publicar-site → WooCommerce (Fase 2/3)
# ============================================

# ---- IA (enriquecimento de produto: título, descrição, tags) ----
# Pegue em: https://console.anthropic.com/settings/keys
# Sem essa chave a aba IA no modal mostra "desligado" — o CEO ainda
# consegue editar tudo à mão.
ANTHROPIC_API_KEY=
# Modelo opcional (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Upload de mídia no WordPress (imagens do produto) ----
# WC REST não aceita upload de imagem via consumer_key — precisa de
# Application Password do WP. Gere em:
#   WP Admin → Usuários → Seu usuário → Application Passwords
# Nome: "LURDS ORDER ONE". Copia a senha que aparece (com espaços).
WP_APP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
# Frontend (Next.js) — só NEXT_PUBLIC_* vaza pro browser
# ============================================
# URL pública do WP Admin (pra botão "abrir no WC" depois de publicar).
# Mesma origem do WC_URL normalmente.
#   NEXT_PUBLIC_WC_ADMIN_URL=https://seusite.com.br

# ============================================
# LIVE OS — Instagram Live Commerce
# ============================================

# Meta App (developers.facebook.com → seu app → Settings → Basic)
META_APP_ID=
META_APP_SECRET=

# Verify token (string que VOCÊ inventa — cola a MESMA no painel Meta)
META_VERIFY_TOKEN=

# Token de longa duração da conta @lurdsplussize (60 dias)
# Gerado quando a conta aceitou ser Tester e autorizou o app
META_PAGE_ACCESS_TOKEN=

# ID numérico da conta @lurdsplussize
META_IG_USER_ID=

# Reservas — TTL padrão durante a live (em minutos)
LIVE_RESERVATION_TTL_MIN=15

# IA Anthropic (deixa em branco se ainda não tem chave)
# A "Lú" só responde se essa chave estiver configurada.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
