# API do flowops (Railway) — backend NestJS
# Em dev local: http://localhost:3001
# Em produção (Vercel): https://api.flowops-lite.com (ou domínio Railway)
NEXT_PUBLIC_API_URL=https://api.flowops-lite.com

# VAPID public key (push notifications) — copia da Railway env vars do backend
# É a mesma do flowops (VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Analytics (opcional — Semana 3)
NEXT_PUBLIC_ANALYTICS_ID=
