// FlowOps Lite - Prisma Schema
//
// Em DEV LOCAL usa SQLite (arquivo backend/prisma/dev.db).
// Em PRODUCAO (Railway) usa Postgres — Railway injeta DATABASE_URL.
//
// A troca é só mudar o provider via env PRISMA_PROVIDER no Railway,
// mas como Prisma não aceita provider via env em tempo de schema,
// deixamos postgresql fixo aqui. Para dev local, usar SQLite num branch
// separado ou criar schema.dev.prisma.
//
// Recomendado em dev: rodar Postgres local via docker-compose (incluso
// no repo — `docker compose up -d db`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums nativos. Usamos String com validação no código.

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   // admin | operator | store
  storeId      String?  @map("store_id")
  store        Store?   @relation(fields: [storeId], references: [id])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  history       OrderHistory[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════════════════════════
// Push Notifications (Web Push API).
// Cada celular/browser/PWA que o usuário usa gera UMA subscription única.
// Vendedora pode ter várias (celular + PC + tablet) — todas recebem o push.
// ═══════════════════════════════════════════════════════════════════════════
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // endpoint é o URL único do servidor de push (Google FCM/Mozilla/Apple).
  // É a "identidade" da subscription — chave única para evitar duplicatas.
  endpoint  String   @unique
  // p256dh + auth são as chaves de criptografia da subscription.
  // Web Push exige cripto end-to-end: backend criptografa payload com p256dh,
  // browser do user descriptografa com chave privada local.
  p256dh    String   // chave pública ECDH base64
  auth      String   // segredo de autenticação base64
  // User-Agent do device pra identificar nas configs (ex: "Chrome Android")
  userAgent String?  @map("user_agent")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  lastUsed  DateTime @default(now()) @map("last_used")

  @@index([userId])
  @@map("push_subscriptions")
}

model Store {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  cep           String?
  city          String?
  state         String?
  whatsapp      String?              // formato E.164 sem +, ex: 5511999999999
  contactName   String?  @map("contact_name")
  active        Boolean  @default(true)
  priorityScore Int      @default(50) @map("priority_score")
  createdAt     DateTime @default(now()) @map("created_at")

  // Categoria operacional/financeira:
  //   REDE   = lojas próprias (sem cobrança intercompany entre si)
  //   FILIAL = franquias (pagam preço/2.5 + 8% royalties + 4% marketing)
  // Usado pra gerar obrigações financeiras automáticas em transferências mistas
  // REDE↔FILIAL. Default REDE pra não quebrar lojas existentes.
  tipo          String   @default("REDE")  // REDE | FILIAL

  // ── Config de Realinhamento ──
  // Controla se a loja participa do balanço automático de estoque entre lojas.
  // Ambos default true (participa de tudo). Casos comuns:
  //   - CD Central: canSend=true, canReceive=false (só abastece)
  //   - Loja nova:  canSend=false, canReceive=true (só recebe)
  //   - Liquidando: canSend=true, canReceive=false (esvaziando)
  //   - Pausada:    canSend=false, canReceive=false (não participa)
  canSendRealign    Boolean  @default(true) @map("can_send_realign")
  canReceiveRealign Boolean  @default(true) @map("can_receive_realign")

  // ── Geofence do PONTO ──
  // Trava anti-fraude: só deixa bater ponto dentro do raio da loja. Opt-in por
  // loja (default off pra não travar quem ainda não configurou coordenadas).
  // pontoLat/pontoLng = coordenadas da loja; pontoRaioM = raio em metros.
  pontoGeofence Boolean @default(false) @map("ponto_geofence")
  pontoLat      Float?  @map("ponto_lat")
  pontoLng      Float?  @map("ponto_lng")
  pontoRaioM    Int     @default(150) @map("ponto_raio_m")

  // ── Consolidação de Grade (Sprint 0) ──
  // Score que define o "peso" da loja como destino quando o sistema
  // CONSOLIDA peças fragmentadas (ex: REF velha, pouca peça, espalhada
  // em várias lojas). Quanto maior, mais a loja é "ímã" pra concentrar
  // grades completas. Default 50 (neutro). Use 100+ pra lojas-âncora.
  consolidationScore Int     @default(50) @map("consolidation_score")

  // Marca a loja como destino preferencial de peças "outlet" (cadastro
  // antigo, baixo giro). Quando true, peças com DATAALT > X dias são
  // consolidadas nessa loja em vez de qualquer outra. Pode ter mais de
  // uma loja outlet; entre elas, decide pelo consolidationScore.
  isOutlet          Boolean  @default(false) @map("is_outlet")

  // ── Auditoria fiscal (grupo com múltiplos CNPJs) ──
  // CNPJ esperado pra essa loja emitir NFC-e. Ex: SOROCABA → T.O. RISSUTTO.
  // Se a config NFC-e da loja apontar pra CNPJ diferente, o PDV bloqueia a
  // emissão e o relatório fiscal marca em vermelho. Só é validado se preenchido.
  expectedCnpj      String?  @map("expected_cnpj")
  expectedRazaoSocial String? @map("expected_razao_social")

  // ── Gateway de pagamento PIX ──
  // Define qual provider PIX a loja usa no PDV. Permite migracao gradual
  // (ex: ITANHAEM em PagBank piloto, demais ainda em Pagar.me).
  //   'auto'    = tenta PagBank primeiro, Pagar.me como fallback (default)
  //   'pagbank' = forca PagBank, sem fallback de gateway externo
  //   'pagarme' = forca Pagar.me, sem fallback de gateway externo
  // Em todos os casos, se o provider escolhido falhar, cai pro PIX local
  // (chave celular) como ultima opcao.
  pixProvider       String   @default("auto") @map("pix_provider")

  users          User[]
  pickOrders     PickOrder[]
  orderItems     OrderItem[]
  supplyRequests SupplyRequest[]
  commissionRules CommissionRule[]
  responsibleSellers Seller[] @relation("StoreResponsibleSellers")
  pontoRegistros  PontoRegistro[]

  // ── CRM / Cashback (expansão 2026-05) ──
  customersOrigin       Customer[]            @relation("CustomerOriginStore")
  // CRM cliente misto (jun/2026): clientes WC que moram perto desta loja.
  // Atribuído por range CEP. Cliente continua originStoreId=SITE mas
  // aparece na lista física desta loja com badge "🌐 SITE".
  customersTarget       Customer[]            @relation("CustomerTargetStore")
  cashbackTransactions  CashbackTransaction[] @relation("StoreCashbackTransactions")

  // CEP ranges atendidos pela loja (raio aproximado).
  // Formato: JSON array de [start, end] (inteiros 5 dígitos sem hífen).
  // Ex: [[11000, 11199], [11500, 11599]]  → Santos
  // Cliente WC com CEP nesses ranges é candidato a "misto" pra esta loja.
  cepRanges     String?  @map("cep_ranges")

  @@map("stores")
}

// ═══════════════════════════════════════════════════════════════════════════
// Obrigações financeiras geradas por transferências entre grupos REDE↔FILIAL.
//
// Regra do negócio:
//   - Quando uma loja envia mercadoria pra OUTRO grupo (REDE → FILIAL ou
//     FILIAL → REDE), gera uma obrigação financeira do RECEPTOR pro REMETENTE.
//   - Valor da obrigação = preço_venda_giga × qty / 2.5
//   - Snapshot do preço NO MOMENTO do envio (mudanças posteriores não afetam).
//   - mesReferencia = mês do envio. Vence no dia 1 do mês seguinte.
//
// Status:
//   pending   = obrigação criada, ainda não fechada nem paga
//   closed    = mês fechado (admin apertou "fechar mês"), virou snapshot
//   paid      = pagamento confirmado pelo admin
//   cancelled = transferência revertida ou cancelada manualmente
// ═══════════════════════════════════════════════════════════════════════════
model InterStoreObligation {
  id                String   @id @default(uuid())
  // Vínculo com a transferência que gerou (auditoria)
  transferOrderId   String   @map("transfer_order_id")
  // Lojas envolvidas + categorias congeladas (preserva histórico mesmo se
  // a loja mudar de tipo depois)
  fromStoreCode     String   @map("from_store_code")
  fromStoreName     String   @map("from_store_name")
  fromStoreTipo     String   @map("from_store_tipo")     // REDE | FILIAL no momento
  toStoreCode       String   @map("to_store_code")
  toStoreName       String   @map("to_store_name")
  toStoreTipo       String   @map("to_store_tipo")
  // Item transferido
  refCode           String   @map("ref_code")
  sku               String?
  cor               String?
  tamanho           String?
  descricao         String?
  qty               Int
  // Valores (snapshot)
  precoUnitario     Float    @map("preco_unitario")     // preço cheio Giga no momento
  precoTotal        Float    @map("preco_total")         // precoUnitario × qty
  divisor           Float    @default(2.5)               // ÷ 2.5 padrão (futuro: configurável por filial)
  valorObrigacao    Float    @map("valor_obrigacao")    // precoTotal / divisor
  // Convenção: TO paga FROM (quem recebeu mercadoria paga quem mandou)
  mesReferencia     String   @map("mes_referencia")     // "YYYY-MM"
  status            String   @default("pending")        // pending | closed | paid | cancelled
  // Pagamento
  paidAt            DateTime? @map("paid_at")
  paidByUserId      String?  @map("paid_by_user_id")
  paidNote          String?  @map("paid_note")
  // Fechamento
  closedAt          DateTime? @map("closed_at")
  closedByUserId    String?  @map("closed_by_user_id")
  // Cancelamento
  cancelledAt       DateTime? @map("cancelled_at")
  cancelReason      String?  @map("cancel_reason")
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([mesReferencia, status])
  @@index([fromStoreCode, mesReferencia])
  @@index([toStoreCode, mesReferencia])
  @@index([transferOrderId])
  @@map("inter_store_obligations")
}

// ═══════════════════════════════════════════════════════════════════════════
// REMESSA de realinhamento — agrupa N TransferOrders num "pacote físico"
// pra dar rastreabilidade de trânsito entre lojas.
//
// Fluxo:
//   1. Vendedora da loja A monta a remessa item a item (status = open)
//      Cada item adicionado vira shipmentId no TransferOrder e seu
//      realignmentStatus vira 'sent'.
//   2. Quando termina, clica "Fechar e enviar" → status vira 'in_transit'
//      Sistema baixa estoque Giga A em batch (todos os itens de uma vez)
//      e emite socket pra loja B receber alerta.
//   3. Loja B vê remessa chegando, bipa cada item à medida que chega.
//      Itens não bipados podem ser marcados como 'missing'.
//   4. "Dar Entrada" → status = 'received'. Sistema chama erp.increaseStock
//      pros itens 'received' (não pros 'missing'). Itens missing têm
//      a obrigação financeira cancelada automaticamente.
//
// Código (`code`): formato REM-YYYY-NNNNNN sequencial global.
// ═══════════════════════════════════════════════════════════════════════════
model RealignmentShipment {
  id                String   @id @default(uuid())
  // Código humano sequencial: REM-2026-000123
  code              String   @unique
  // Lojas envolvidas
  fromStoreCode     String   @map("from_store_code")
  fromStoreName     String   @map("from_store_name")
  toStoreCode       String   @map("to_store_code")
  toStoreName       String   @map("to_store_name")
  // REALINHAMENTO (triagem automática) | TRANSFERENCIA (ponto a ponto manual).
  // Separa as caixas pra não misturar manual com automático.
  tipo              String   @default("REALINHAMENTO")
  // Status: open | in_transit | received | cancelled
  status            String   @default("open")
  // Timestamps por etapa
  openedAt          DateTime @default(now()) @map("opened_at")
  openedByUserId    String?  @map("opened_by_user_id")
  sentAt            DateTime? @map("sent_at")
  sentByUserId      String?  @map("sent_by_user_id")
  receivedAt        DateTime? @map("received_at")
  receivedByUserId  String?  @map("received_by_user_id")
  // Quantidades (snapshots calculados no fechamento)
  totalItems        Int      @default(0) @map("total_items")    // qtd de TransferOrders na remessa
  totalQty          Int      @default(0) @map("total_qty")       // soma das quantidades
  receivedQty       Int      @default(0) @map("received_qty")    // qty efetivamente recebida
  missingQty        Int      @default(0) @map("missing_qty")     // qty marcada como faltante
  // Marcador de baixa Giga: setado quando decreaseStock origem rodou com sucesso.
  // Permite reprocessar remessas que fecharam mas o estoque não baixou (idempotência).
  stockDecreasedAt  DateTime? @map("stock_decreased_at")
  // Marcador de aumento Giga no destino: setado quando confirmReceived rodou.
  stockIncreasedAt  DateTime? @map("stock_increased_at")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([fromStoreCode, status])
  @@index([toStoreCode, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("realignment_shipments")
}

// Fechamento mensal — snapshot imutável de royalties + marketing + obrigações.
// Criado quando admin aperta "Fechar mês X". Vira o demonstrativo oficial.
model MonthlyClosure {
  id                String   @id @default(uuid())
  mesReferencia     String   @unique @map("mes_referencia") // "2026-04"
  closedAt          DateTime @default(now()) @map("closed_at")
  closedByUserId    String?  @map("closed_by_user_id")
  // Resumo geral
  totalObrigacoes   Float    @default(0) @map("total_obrigacoes")
  totalRoyalties    Float    @default(0) @map("total_royalties")
  totalMarketing    Float    @default(0) @map("total_marketing")
  // Detalhamento serializado em JSON (por filial)
  // [{storeCode, storeName, vendaBruta, royaltiesValor, marketingValor,
  //   obrigacoesAPagar, obrigacoesAReceber, saldoLiquido}]
  detalhePorFilial  String   @map("detalhe_por_filial") // JSON
  notes             String?

  @@map("monthly_closures")
}

// Conta corrente da franqueada — lançamentos MANUAIS (pagamentos + ajustes).
// Os DÉBITOS automáticos (obrigações ÷2,5 + royalties 8% + marketing 4%) NÃO
// ficam aqui: são calculados na hora a partir do que o sistema já tem. Aqui só
// entram os lançamentos manuais, cada um com documento (comprovante) opcional.
// Há UMA franqueada só (todas as FILIAL = mesmo dono) → sem vínculo de loja.
model FranquiaLancamento {
  id            String   @id @default(uuid())
  data          DateTime                              // data do pagamento/ajuste
  tipo          String                                // 'pagamento' | 'ajuste'
  natureza      String                                // 'credito' (reduz saldo) | 'debito' (aumenta)
  descricao     String
  valorCents    Int      @map("valor_cents")          // sempre positivo
  documentoUrl  String?  @map("documento_url")
  documentoNome String?  @map("documento_nome")
  criadoPorId   String?  @map("criado_por_id")
  criadoPorNome String?  @map("criado_por_nome")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([data])
  @@map("franquia_lancamentos")
}

model Order {
  id              String   @id @default(uuid())
  wcOrderId       Int      @unique @map("wc_order_id")
  wcOrderNumber   String?  @map("wc_order_number")
  // Origem do pedido: 'site' (WooCommerce) ou 'live' (Live Commerce).
  // Pedido da LIVE entra no MESMO trilho do site (decisão do dono, 12/07):
  // wcOrderId sintético (900M+), sem sync com WooCommerce (guards por source).
  source          String   @default("site")
  liveCartId      String?  @unique @map("live_cart_id") // LivePdvCart.id de origem
  status          String   // pending, routing, awaiting_stock, separating, ready, shipped, delivered, cancelled
  customerName    String?  @map("customer_name")
  customerEmail   String?  @map("customer_email")
  customerPhone   String?  @map("customer_phone")
  customerCpf     String?  @map("customer_cpf")     // CPF do cliente (extraído de meta_data do WC)
  shippingCep     String?  @map("shipping_cep")
  shippingAddress String   @map("shipping_address") // JSON serializado
  totalAmount     Float?   @map("total_amount")
  trackingCode    String?  @map("tracking_code")
  carrier         String?
  routingResult   String?  @map("routing_result") // JSON serializado
  // ── Pickup (retirada em loja) ──
  isPickup        Boolean  @default(false) @map("is_pickup")          // true quando WC shipping = "Retirar na loja X"
  pickupStoreCode String?  @map("pickup_store_code")                   // código da loja onde cliente vai retirar (LJ05 etc)
  shippingMethod  String?  @map("shipping_method")                      // título do método de envio do WC (pra UI)
  wcDateCreated   DateTime? @map("wc_date_created") // data que o cliente fez o pedido no site
  // ── Atribuição de venda (atendente que iniciou o contato — cliente fecha no site) ──
  // Marcação manual via UI (operadora matriz). Relatório mensal soma por vendedora.
  sellerId        String?   @map("seller_id")
  sellerName      String?   @map("seller_name") // cache denormalizado pra relatório não depender de JOIN
  sellerAssignedAt DateTime? @map("seller_assigned_at")
  sellerAssignedBy String?   @map("seller_assigned_by") // email do usuário matriz que atribuiu
  createdAt       DateTime @default(now()) @map("created_at") // data que chegou no FlowOps
  updatedAt       DateTime @updatedAt @map("updated_at")

  items      OrderItem[]
  pickOrders PickOrder[]
  history    OrderHistory[]
  seller     Seller? @relation(fields: [sellerId], references: [id])

  @@index([status])
  @@index([sellerId])
  @@index([source])
  @@map("orders")
}

// Vendedoras — cadastro de atendentes que iniciam vendas online (exemplos: Karine, Manu).
// Cliente que tira dúvida com a vendedora via WhatsApp e depois fecha no site fica marcado
// com o sellerId — relatório mensal mostra performance de cada uma.
// Soft-delete via `active=false`. Nome é único case-insensitive (validação na service).
model Seller {
  id        String   @id @default(uuid())
  name      String   @unique
  whatsapp  String?  // opcional — pra matriz saber contato da vendedora
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Cargo determina a regra de comissão:
  //   VENDEDORA  → % sobre vendas próprias
  //   LIDER_B    → 0,5% sobre TODA a loja que responde
  //   LIDER_A    → 1,0% sobre TODA a loja que responde
  //   GERENTE_B  → 1,5% sobre TODA a loja que responde
  //   GERENTE_A  → 2,0% sobre TODA a loja que responde
  cargo            String   @default("VENDEDORA")

  // Pra LIDER/GERENTE: ID da loja pela qual responde (calcula % sobre ela toda).
  // Se cargo=VENDEDORA, fica null (comissão é sobre vendas próprias dela onde
  // quer que ela venda — pode rodar em mais de uma loja).
  responsibleStoreId String? @map("responsible_store_id")

  // Codigo da funcionaria no Wincred (importada via PdvActiveSeller).
  // Usado pra rastrear vendas PDV físicas (codigo bipado vira sellerId).
  // Null pra Sellers criados manualmente (Karine, Manu — só atribuem WC).
  wincredCodigo      String? @map("wincred_codigo")
  // Loja onde foi originalmente importada (pra agrupamento). Pode mudar.
  storeCodeOrigin    String? @map("store_code_origin")

  // ── PRONTUARIO RH ────────────────────────────────────────────────
  cpf                String?  @db.VarChar(14)
  rg                 String?  @db.VarChar(20)
  dataNascimento     DateTime? @map("data_nascimento") @db.Date
  email              String?  @db.VarChar(120)
  endereco           String?  @db.VarChar(200)
  cidade             String?  @db.VarChar(80)
  uf                 String?  @db.Char(2)
  cep                String?  @db.VarChar(10)
  // Contratacao
  dataAdmissao       DateTime? @map("data_admissao") @db.Date
  contratoTipo       String?  @map("contrato_tipo") @db.VarChar(30)  // CLT, PJ, ESTAGIO, FREELA
  cargoFuncao        String?  @map("cargo_funcao") @db.VarChar(60)   // titulo do cargo (Vendedora Junior, etc)
  salarioBase        Decimal? @map("salario_base") @db.Decimal(10, 2)
  // Horario trabalho: JSON com array de turnos {dia, inicio, fim}
  // Ex: [{dia:'SEG', inicio:'09:00', fim:'18:00'}, ...]
  horarioTrabalho    String?  @map("horario_trabalho") @db.Text
  // Ferias
  dataInicioFerias   DateTime? @map("data_inicio_ferias") @db.Date
  dataFimFerias      DateTime? @map("data_fim_ferias") @db.Date
  // Saude/dados sensiveis
  observacoes        String?  @db.Text
  documents          SellerDocument[]

  // ── PONTO ELETRONICO (FACE-API.JS) ────────────────────────────
  // Array JSON de descriptors faciais (cada um 128 floats).
  // Gerados pelo face-api.js no browser durante o cadastro do rosto
  // (3 capturas em angulos diferentes pra ganho de precisao).
  faceDescriptors    String?   @map("face_descriptors") @db.Text
  faceEnrolledAt     DateTime? @map("face_enrolled_at")
  faceSnapshotUrl    String?   @map("face_snapshot_url") @db.Text  // foto de referencia (audit)
  pontoRegistros     PontoRegistro[]

  orders Order[]
  commissionRules    CommissionRule[]
  commissionEntries  CommissionEntry[]
  responsibleStore   Store? @relation("StoreResponsibleSellers", fields: [responsibleStoreId], references: [id])

  @@index([active, name])
  @@index([cargo, active])
  @@index([responsibleStoreId])
  @@index([cpf])
  @@index([dataAdmissao])
  @@map("sellers")
}

/// Documentos do prontuario da funcionaria — contrato, atestados,
/// recibos, RG/CPF, etc. Armazena URL do arquivo no R2 + metadata.
model SellerDocument {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  // Categoria — pra agrupar no prontuario
  // 'documento_pessoal' | 'contrato' | 'recibo_pagamento' | 'atestado' | 'ferias' | 'outro'
  categoria   String   @db.VarChar(30)
  // Nome legivel (ex: "RG frente", "Atestado dr Silva 12/06")
  titulo      String   @db.VarChar(200)
  // URL no R2 (objects.lurds.com.br/...)
  fileUrl     String   @map("file_url") @db.Text
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type") @db.VarChar(80)
  // Data referencia do documento (ex: data do atestado, mes do recibo)
  dataReferencia DateTime? @map("data_referencia") @db.Date
  // Notas livres
  observacoes String?  @db.Text

  uploadedAt  DateTime @default(now()) @map("uploaded_at")
  uploadedBy  String?  @map("uploaded_by")  // userId

  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, categoria])
  @@index([sellerId, uploadedAt])
  @@map("seller_documents")
}

/// PontoRegistro — registro de ponto eletronico (REP-A Portaria 671/2021).
///
/// Cada batida e UMA linha aqui. Tipos:
///   - entrada       : inicio do expediente
///   - saida_almoco  : saida pro intervalo intrajornada
///   - volta_almoco  : retorno do intervalo
///   - saida         : encerramento do expediente
///
/// Source identifica a origem do registro pra audit:
///   - face_pdv     : reconhecimento facial na webcam do PDV (face-api.js)
///   - pwa_selfie   : selfie + geolocalizacao no PWA da funcionaria
///   - manual_admin : registro manual ou correcao pelo admin RH
///
/// Timestamp e sempre do servidor (nunca do cliente) pra integridade.
model PontoRegistro {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  storeId     String   @map("store_id")    // loja onde bateu
  tipo        String   @db.VarChar(20)     // entrada | saida_almoco | volta_almoco | saida
  timestamp   DateTime @default(now())     // batido pelo servidor

  source      String   @db.VarChar(20)     // face_pdv | pwa_selfie | manual_admin
  // Confianca do match facial (1 - distancia euclidiana). Mais perto de 1 = mais confiante.
  faceConfidence Float?  @map("face_confidence")
  // URL R2 da selfie do momento da batida (so face_pdv/pwa_selfie). Audit + duvida.
  faceSnapshot   String? @map("face_snapshot") @db.Text

  // Geolocalizacao (so pwa_selfie geralmente)
  lat         Float?
  lng         Float?
  ip          String?  @db.VarChar(45)

  // Audit do bater fora do padrao
  observacoes String?  @db.Text

  // Marcador de "registro originalmente faltante, corrigido manualmente pelo admin"
  justificado    Boolean @default(false)
  justificativa  String? @db.Text
  justificadoBy  String? @map("justificado_by")   // userId admin
  justificadoAt  DateTime? @map("justificado_at")

  createdAt   DateTime @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id])

  @@index([sellerId, timestamp])
  @@index([storeId, timestamp])
  @@index([timestamp])
  @@map("ponto_registros")
}

// ── COMISSÕES (F4) ──────────────────────────────────────────────────
//
// 3 tabelas pro motor de comissão:
//   1. CommissionRule       — regras de cálculo (% base, meta, bônus)
//   2. CommissionPeriod     — fechamentos mensais (open/closed/paid)
//   3. CommissionEntry      — linha de cálculo por vendedora no período
//
// Quando você desligar o Wincred dia 30/06, o cálculo de comissão precisa
// rodar 100% no Flowops. Hoje vem do Giga — vamos migrar.
//
// Regras têm escopo hierárquico:
//   - scope='global'  → vale pra todas as vendedoras
//   - scope='store'   → vale só pras vendedoras da loja X
//   - scope='seller'  → vale só pra vendedora Y (sobrescreve as outras)
//
// Quando calcula, busca da MAIS específica pra MENOS:
//   seller(Y) > store(X) > global → primeira que match é a usada.
//
model CommissionRule {
  id            String   @id @default(uuid())
  // Escopo: por cargo (mais comum), global, store específica ou seller específica
  scope         String   // 'cargo' | 'global' | 'store' | 'seller'
  cargo         String?  // quando scope='cargo': VENDEDORA | LIDER_B | LIDER_A | GERENTE_B | GERENTE_A
  storeId       String?  @map("store_id")
  sellerId      String?  @map("seller_id")

  // Como calcular:
  //   'on_self'              → % sobre vendas próprias da vendedora
  //   'on_responsible_store' → % sobre TOTAL da loja responsável (cargo líder/gerente)
  // Default 'on_self' pra retrocompatibilidade.
  calcMode      String   @default("on_self") @map("calc_mode")

  // Cálculo: % sobre venda líquida (vendido - trocas/devoluções)
  percentBase   Decimal  @map("percent_base")  @db.Decimal(5, 2)  // ex: 3.00 = 3%

  // Meta opcional: se vendedora bater a meta no período, ganha bônus
  meta          Decimal? @db.Decimal(12, 2)  // ex: 80000.00 = R$ 80k/mês
  bonusPercent  Decimal? @map("bonus_percent") @db.Decimal(5, 2)  // ex: 1.00 = +1% acima da meta

  // Vigência — admin pode criar regra futura ou desativar
  validFrom     DateTime @map("valid_from")
  validTo       DateTime? @map("valid_to")
  active        Boolean  @default(true)

  // Notas livres pra admin lembrar o motivo da regra
  note          String?  @db.Text

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by")  // userId do admin

  store         Store?   @relation(fields: [storeId], references: [id])
  seller        Seller?  @relation(fields: [sellerId], references: [id])

  @@index([scope, active])
  @@index([cargo, active])
  @@index([storeId, active])
  @@index([sellerId, active])
  @@index([validFrom, validTo])
  @@map("commission_rules")
}

// Período de fechamento — mensal por enquanto (yyyy-mm)
model CommissionPeriod {
  id          String   @id @default(uuid())
  yearMonth   String   @unique @map("year_month")  // '2026-06'
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")

  // 'open'   — em cálculo, ainda recebe vendas
  // 'closed' — fechado, valores finais não mudam mais
  // 'paid'   — comissão paga pra todas as vendedoras
  status      String   @default("open")
  closedAt    DateTime? @map("closed_at")
  closedBy    String?  @map("closed_by")  // userId do admin
  paidAt      DateTime? @map("paid_at")

  // Snapshot agregado pra dashboard rápido
  totalSellers      Int     @default(0) @map("total_sellers")
  totalCommission   Decimal @default(0) @map("total_commission") @db.Decimal(12, 2)
  totalVendido      Decimal @default(0) @map("total_vendido") @db.Decimal(12, 2)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entries     CommissionEntry[]

  @@index([status])
  @@map("commission_periods")
}

// Linha de cálculo por vendedora × loja × período
model CommissionEntry {
  id          String   @id @default(uuid())
  periodId    String   @map("period_id")
  sellerId    String   @map("seller_id")
  storeId     String   @map("store_id")

  // Valores do período
  totalVendido       Decimal @map("total_vendido") @db.Decimal(12, 2)
  totalTrocas        Decimal @default(0) @map("total_trocas") @db.Decimal(12, 2)
  vendidoLiquido     Decimal @map("vendido_liquido") @db.Decimal(12, 2)
  qtdVendas          Int     @default(0) @map("qtd_vendas")

  // Cálculo
  percentApplied     Decimal @map("percent_applied") @db.Decimal(5, 2)
  comissaoBase       Decimal @map("comissao_base") @db.Decimal(12, 2)
  metaAtingida       Boolean @default(false) @map("meta_atingida")
  metaValue          Decimal? @map("meta_value") @db.Decimal(12, 2)
  bonusPercent       Decimal? @map("bonus_percent") @db.Decimal(5, 2)
  bonusValue         Decimal @default(0) @map("bonus_value") @db.Decimal(12, 2)
  total              Decimal @db.Decimal(12, 2)

  // Auditoria: snapshot da regra que foi usada (rastreabilidade)
  ruleSnapshot       Json    @map("rule_snapshot")
  ruleId             String? @map("rule_id")  // opcional pra debug

  calculatedAt       DateTime @default(now()) @map("calculated_at")
  paidAt             DateTime? @map("paid_at")
  paidBy             String?  @map("paid_by")

  period             CommissionPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  seller             Seller @relation(fields: [sellerId], references: [id])

  @@unique([periodId, sellerId, storeId])
  @@index([sellerId, calculatedAt])
  @@index([storeId, calculatedAt])
  @@map("commission_entries")
}

// Tabela KV genérica pra config do app que precisa sobreviver a redeploys.
// Usada pra coords do carnê / promissória editadas pelo painel admin.
// O /tmp do Railway some a cada deploy — Postgres nao.
model AppConfig {
  key       String   @id
  valueJson String   @db.Text @map("value_json")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

// Vendedoras ATIVAS por loja — whitelist pra o PDV mostrar so as que
// realmente atendem ali. Evita o modal Vendedora puxar todos os 80+
// funcionarios da tabela funcionarios do Wincred.
// Admin marca quais funcionarias ficam visiveis no PDV de cada loja.
// Codigo e nome vem da tabela funcionarios do Wincred (snapshot).
model PdvActiveSeller {
  id        String   @id @default(uuid())
  storeCode String   @map("store_code")
  codigo    String
  nome      String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([storeCode, codigo])
  @@index([storeCode])
  @@map("pdv_active_sellers")
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String  @map("order_id")
  sku             String
  productName     String? @map("product_name")
  quantity        Int
  unitPrice       Float?  @map("unit_price")
  assignedStoreId String? @map("assigned_store_id")

  order         Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedStore Store? @relation(fields: [assignedStoreId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model PickOrder {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  storeId      String   @map("store_id")
  status       String   // new, separating, ready, shipped
  trackingCode String?  @map("tracking_code")
  carrier      String?
  // ── Transferência entre lojas (quando pedido é retirada em loja e loja destino não tem estoque) ──
  isTransfer           Boolean @default(false) @map("is_transfer")             // true = separar e enviar pra outra loja, não pro cliente
  transferToStoreCode  String? @map("transfer_to_store_code")                   // loja que vai RECEBER a transferência (loja de retirada)
  customerSnapshot     String? @map("customer_snapshot")                        // JSON com nome/cpf/email/tel — cliente que vai retirar
  // ── Aprovação de baixa (matriz) — independente do status logístico ──
  // Loja posta (shipped + tracking) sem esperar esse campo. Matriz aprova em paralelo.
  debitApprovedAt      DateTime? @map("debit_approved_at")
  debitApprovedBy      String?   @map("debit_approved_by")
  // ── Sinalização de problema pela loja (sem estoque físico, peça c/ defeito, divergência) ──
  // Loja reporta → card sai da fila dela → matriz vê flag + motivo e recalcula p/ outra loja
  issueReason          String?   @map("issue_reason")                              // out_of_stock | defective | divergence | other
  issueNote            String?   @map("issue_note")
  issueReportedAt      DateTime? @map("issue_reported_at")
  issueReportedBy      String?   @map("issue_reported_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId, status])
  @@map("pick_orders")
}

model OrderHistory {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  userId     String?  @map("user_id")
  fromStatus String?  @map("from_status")
  toStatus   String?  @map("to_status")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  // Histórico carregado por pedido (include history orderBy createdAt desc) e
  // contado por usuário (users.service). Sem índice, era full-scan.
  @@index([orderId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("order_history")
}

model IntegrationLog {
  id        Int      @id @default(autoincrement())
  source    String
  direction String
  event     String
  payload   String?
  status    Int?
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([source, event, createdAt(sort: Desc)])
  @@map("integration_logs")
}

// Key-value simples pra flags globais do sistema (ligar/desligar Piloto
// Automático, pausar crons, etc). Single source of truth — substitui
// localStorage do client pra configs que devem valer pra TODOS os usuários
// e pro worker server-side que roda sem aba aberta.
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ==========================================================================
// MARKETING — Recuperação de Carrinho via WhatsApp
// ==========================================================================
// Cada WaMessage representa 1 mensagem agendada OU enviada (manual ou
// automática) no processo de recuperação. Chave natural de dedup:
// (sourceType, sourceId, stepIndex) — não manda o mesmo estágio 2x pro mesmo
// carrinho. Cross-reference com Order por (customerEmail OR customerPhone)
// pra detectar conversão.

model WaMessage {
  id               String    @id @default(uuid())
  stepIndex        Int       @map("step_index")       // 0 = T1 (1h), 1 = T2 (24h), 2 = T3 (72h)
  // Identificação do destinatário
  customerPhone    String    @map("customer_phone")    // E.164 sem +, ex 5511999999999
  customerEmail    String?   @map("customer_email")
  customerName     String?   @map("customer_name")
  // Referência ao gatilho
  sourceType       String    @map("source_type")       // "cart" | "wc-pending" (fallback)
  sourceId         String    @map("source_id")         // id do abandoned cart OU wc order id
  sourceAmount     Float?    @map("source_amount")     // valor do carrinho (pra KPI de R$ recuperado)
  // Status
  status           String    // queued | sent | delivered | read | failed | skipped | converted
  scheduledFor     DateTime  @map("scheduled_for")
  sentAt           DateTime? @map("sent_at")
  deliveredAt      DateTime? @map("delivered_at")
  readAt           DateTime? @map("read_at")
  failedAt         DateTime? @map("failed_at")
  failReason       String?   @map("fail_reason")
  // Conteúdo
  bodyRendered     String?   @map("body_rendered")     // texto renderizado final
  templateKey      String?   @map("template_key")      // nome do template Meta (fase 2)
  waMessageId      String?   @map("wa_message_id")     // id retornado pela Meta API
  sendMode         String    @default("manual") @map("send_mode") // manual | auto
  sentBy           String?   @map("sent_by")            // userId que disparou no modo manual
  // Cupom
  couponCode       String?   @map("coupon_code")
  couponPct        Int?      @map("coupon_pct")
  // Conversão
  convertedAt      DateTime? @map("converted_at")
  convertedOrderId String?   @map("converted_order_id") // Order.id local
  convertedAmount  Float?    @map("converted_amount")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([customerPhone])
  @@index([sourceType, sourceId, stepIndex])
  @@index([status, scheduledFor])
  @@map("wa_messages")
}

model WaOptOut {
  id        String   @id @default(uuid())
  phone     String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("wa_opt_outs")
}

// ==========================================================================
// TRANSFER ORDERS — Histórico de pedidos de transferência entre lojas
// ==========================================================================
// Cada vez que a filial aperta "Pedir" na tela /minha-loja/consultar pra
// pedir uma peça de outra loja, a gente registra aqui ANTES de abrir o
// WhatsApp. Serve de histórico pra gerência acompanhar giro de pedidos,
// identificar lojas que mais transferem, cliente que tá comprando muito
// sem estoque local, etc.
//
// Não temos ainda confirmação de "foi transferido de fato" — isso fica
// pra uma fase 2 (matriz aprova + baixa no ERP). Aqui é só o log do
// pedido que saiu via WhatsApp.

// ==========================================================================
// SUPPLIES — Almoxarifado (materiais de uso diário das filiais)
// ==========================================================================
// Filial pede saquinho, durex, bobina, etiqueta, etc pra matriz. Matriz cadastra
// o catálogo em SupplyItem, recebe SupplyRequest, aprova e envia.
//
// Workflow de status do pedido:
//   pending → approved → separating → shipped → delivered
//     └→ cancelled (em qualquer momento antes de shipped)

model SupplyItem {
  id          String   @id @default(uuid())
  sku         String?  @unique               // opcional, código interno da matriz
  name        String                          // ex: "Saquinho 30x40 transparente"
  category    String?                         // ex: Embalagem, Impressão, Limpeza
  unit        String   @default("un")         // un, kg, m, pacote, rolo, caixa
  description String?
  imageUrl    String?  @map("image_url")
  active      Boolean  @default(true)
  minQty      Int?     @map("min_qty")        // estoque mínimo de referência (futuro)
  // Onde a matriz compra/separa esse item. Usado pra matriz saber se tira
  // do estoque interno (MATRIZ) ou se precisa comprar no Mercado Livre (ML).
  // Valores: 'MATRIZ' (default, vem do almoxarifado da matriz) | 'MERCADO_LIVRE'
  origin      String   @default("MATRIZ")     // MATRIZ | MERCADO_LIVRE
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  requestItems SupplyRequestItem[]

  @@index([active, category])
  @@map("supply_items")
}

model SupplyRequest {
  id              String   @id @default(uuid())
  requestNumber   Int      @unique @default(autoincrement()) @map("request_number") // #SR-001
  storeId         String   @map("store_id")
  status          String   // pending | approved | separating | shipped | delivered | cancelled
  note            String?                                     // observação da filial
  adminNote       String?  @map("admin_note")                  // observação da matriz
  // Rastreio do envio
  trackingCode    String?  @map("tracking_code")
  carrier         String?
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  // Quem criou (user da filial)
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id])
  items SupplyRequestItem[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("supply_requests")
}

model SupplyRequestItem {
  id              String  @id @default(uuid())
  requestId       String  @map("request_id")
  supplyItemId    String  @map("supply_item_id")
  qtyRequested    Int     @map("qty_requested")
  qtyApproved     Int?    @map("qty_approved")   // matriz pode aprovar qtd menor
  qtyShipped      Int?    @map("qty_shipped")    // efetivamente enviado

  request SupplyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supply  SupplyItem    @relation(fields: [supplyItemId], references: [id])

  @@index([requestId])
  @@map("supply_request_items")
}

model TransferOrder {
  id                String   @id @default(uuid())
  tipo              String   // REPOSICAO | VENDA_CERTA | REALINHAMENTO
  refCode           String   @map("ref_code")           // ex: VMS-223
  codigoBipado      String?  @map("codigo_bipado")        // CODIGO real do Giga resolvido no bipe (ex: 11132233). Usado pra baixar estoque sem ambiguidade. NULL em items antigos (pré-feature).
  descricao         String?                                // ex: "VESTIDO MIDI ESTAMPA PRETO" (descrição completa do Giga)
  cor               String?                                // ex: PRETO (null = cor não especificada no pedido)
  tamanho           String?                                // ex: 46    (null = tamanho não especificado)
  qtyOrigem         Int      @map("qty_origem")          // qtd na loja de origem no momento do pedido
  // Preço CHEIO unitário (centavos), snapshot no bipe. Usado na conferência da
  // transferência e no impresso (valor inteiro, p/ bater com a etiqueta). O ÷2,5
  // do acerto da franquia é aplicado só na tela de Franquias.
  precoUnitCents    Int?     @map("preco_unit_cents")
  // Loja que VAI MANDAR (origem)
  lojaOrigemCode    String   @map("loja_origem_code")
  lojaOrigemName    String   @map("loja_origem_name")
  // Loja que PEDIU (destino / minha loja)
  lojaDestinoCode   String   @map("loja_destino_code")
  lojaDestinoName   String   @map("loja_destino_name")
  // Quem solicitou
  solicitanteNome   String   @map("solicitante_nome")
  clienteNome       String?  @map("cliente_nome")         // só pra VENDA_CERTA
  // Mensagem enviada via WhatsApp (pra auditoria)
  mensagem          String
  // Quem criou no sistema (do JWT)
  createdByUserId   String?  @map("created_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")

  // ── Controle de VENDA CERTA (anti-malandragem) ──
  // Só é preenchido quando tipo=VENDA_CERTA. Loja destino tem prazo pra
  // confirmar a venda — se não confirmar, matriz vê em vermelho e cobra.
  saleStatus            String?   @map("sale_status")             // pending | confirmed | cancelled
  saleDeadline          DateTime? @map("sale_deadline")            // prazo pra confirmar (default +7d)
  saleConfirmedAt       DateTime? @map("sale_confirmed_at")
  saleConfirmedByUserId String?   @map("sale_confirmed_by_user_id")
  saleCancelReason      String?   @map("sale_cancel_reason")       // por que não rolou a venda
  saleNote              String?   @map("sale_note")                // ex: número do pedido WC, valor

  // ── VENDA CERTA com envio DIRETO PRA CLIENTE ──
  // Quando entregaDireto=true, a peça não vai pra loja destino: vai SEDEX/PAC/
  // MOTOBOY direto pro endereço da cliente. Evita a cliente ter que passar
  // na loja pra retirar. bundleId agrupa várias peças de um mesmo pedido
  // (mesma cliente, mesmo endereço, mesmo frete) pra permitir "adicionar mais
  // uma peça nesse mesmo pacote".
  entregaDireto         Boolean   @default(false) @map("entrega_direto")
  clienteCpf            String?   @map("cliente_cpf")
  clienteTelefone       String?   @map("cliente_telefone")
  enderecoCep           String?   @map("endereco_cep")
  enderecoLogradouro    String?   @map("endereco_logradouro")
  enderecoNumero        String?   @map("endereco_numero")
  enderecoComplemento   String?   @map("endereco_complemento")
  enderecoBairro        String?   @map("endereco_bairro")
  enderecoCidade        String?   @map("endereco_cidade")
  enderecoUf            String?   @map("endereco_uf")
  formaEnvio            String?   @map("forma_envio")              // SEDEX | PAC | MOTOBOY | OUTRO
  // bundleId agrupa N peças do mesmo pedido (mesma cliente, mesmo endereço).
  // Preenchido só quando entregaDireto=true. UI mostra todas as peças juntas.
  bundleId              String?   @map("bundle_id")

  // ── Controle de REALINHAMENTO in-app (filial vê alerta) ──
  // Status do ITEM individual no ciclo de remessa:
  //   pending   → chegou na loja origem, operador ainda não separou
  //   sent      → vendedora origem marcou como separado e adicionou à remessa
  //                (vai junto quando shipment.status vira in_transit)
  //   received  → loja destino bipou, conferiu e deu entrada (+ estoque Giga B)
  //   missing   → veio na remessa mas NÃO chegou fisicamente (extraviada).
  //                Não dá entrada Giga, e cancela a obrigação financeira.
  //   cancelled → matriz cancelou antes de enviar
  realignmentStatus     String?   @map("realignment_status")
  realignmentSentAt     DateTime? @map("realignment_sent_at")
  realignmentSentByUserId String? @map("realignment_sent_by_user_id")
  // Loja origem reporta que NÃO encontrou a peça fisicamente na arara
  // (peça sumiu, etiqueta errada, estoque divergente). Diferente de
  // realignmentMissing* (que é pro DESTINO marcar item que não chegou).
  // Matriz revê esses itens no /retaguarda/realinhamento.
  realignmentNotFoundAt    DateTime? @map("realignment_not_found_at")
  realignmentNotFoundNote  String?   @map("realignment_not_found_note")
  realignmentNotFoundByUserId String? @map("realignment_not_found_by_user_id")
  // Recebimento (loja destino dá entrada)
  realignmentReceivedAt     DateTime? @map("realignment_received_at")
  realignmentReceivedByUserId String? @map("realignment_received_by_user_id")
  // Marcação como faltante (extraviada na remessa)
  realignmentMissingAt      DateTime? @map("realignment_missing_at")
  realignmentMissingNote    String?   @map("realignment_missing_note")
  // FK pra remessa que agrupou esse item
  shipmentId            String?   @map("shipment_id")

  @@index([lojaDestinoCode, createdAt(sort: Desc)])
  @@index([lojaOrigemCode, createdAt(sort: Desc)])
  @@index([refCode, createdAt(sort: Desc)])
  @@index([tipo, saleStatus, createdAt(sort: Desc)])
  @@index([tipo, realignmentStatus, lojaOrigemCode])
  @@index([bundleId])
  @@map("transfer_orders")
}

// ═══════════════════════════════════════════════════════════════════════════
// Publicação de produtos Wincred → WooCommerce
//
// Fluxo de 3 fases:
//   Fase 1 (queued)      — CEO filtra REFs no LURDS ORDER ONE e marca pra subir.
//                          Cada cor da REF vira UMA linha aqui (regra: cada
//                          cor é um produto separado no site).
//   Fase 2 (enriched)    — CEO adiciona descrição, categorias WC, tags,
//                          imagens. Sistema guarda tudo aqui antes de subir.
//   Fase 3 (published)   — Sistema posta no WC via REST, cria produto variável
//                          com variações (1 por tamanho), linka wcProductId.
//
// Por que separar por COR:
//   O site vende PRETO e AZUL como 2 cards distintos na categoria — o cliente
//   enxerga duas peças, não uma com swatch. Isso é decisão de visual/UX do
//   site. No Wincred eles dividem a mesma referência em cores pra controle
//   interno, mas no site cada cor vira um SKU próprio.
//
// Idempotência:
//   Unique (refCode, cor) — não deixa duplicar. Se CEO marcar a mesma
//   REF+COR duas vezes, a segunda é ignorada/atualizada (upsert).
// ═══════════════════════════════════════════════════════════════════════════
model SitePublishQueue {
  id              String   @id @default(uuid())

  // Identificação Wincred
  refCode         String   @map("ref_code")           // ex: 01010101 (REFERENCIA do Wincred)
  cor             String                                 // ex: PRETO (uma linha por cor)
  gigaCodes       Json     @map("giga_codes")          // ["5394104","5394111",...] códigos da variação por tamanho
  fornecedor      String?
  grupo           String?                                // ex: BLUSA FEMININA
  subgrupo        String?                                // ex: MANGA CURTA
  ncm             String?                                // ex: 61062000
  cfop            String?                                // ex: 5102
  custoMedio      Decimal? @map("custo_medio")         @db.Decimal(10, 2)
  precoSugerido   Decimal? @map("preco_sugerido")      @db.Decimal(10, 2)
  estoqueTotal    Int?     @map("estoque_total")       // soma de todas as lojas no momento da marcação
  tamanhos        Json                                    // [{tamanho:"46", codigo:"5394104", estoque:9}, ...]

  // Status do pipeline
  status          String   @default("queued")          // queued | enriched | publishing | published | failed

  // Fase 2 — enriquecimento pra WC
  wcTitulo         String?  @map("wc_titulo")          @db.Text
  wcCategoryIds    Json?    @map("wc_category_ids")    // [123, 456]
  wcTags           Json?    @map("wc_tags")            // ["vestido plus size","verão"]
  wcAtributos      Json?    @map("wc_atributos")       // [{nome:"Tecido",valor:"Viscose"},...]
  wcDescricao      String?  @map("wc_descricao")       @db.Text
  wcDescricaoCurta String?  @map("wc_descricao_curta") @db.Text
  wcImagens        Json?    @map("wc_imagens")         // [{url:"...",alt:"..."},...]
  wcPesoKg         Decimal? @map("wc_peso_kg")         @db.Decimal(6, 3)
  wcDimensoesCm    Json?    @map("wc_dimensoes_cm")    // {comprimento:7,largura:20,altura:30}
  wcPrecoVenda     Decimal? @map("wc_preco_venda")     @db.Decimal(10, 2)
  wcPrecoPromo     Decimal? @map("wc_preco_promo")     @db.Decimal(10, 2)
  aiGeneratedAt    DateTime? @map("ai_generated_at")
  aiModel          String?  @map("ai_model")           // ex: claude-sonnet-4-6

  // Fase 3 — resultado da publicação
  wcProductId     Int?     @map("wc_product_id")
  wcVariationIds  Json?    @map("wc_variation_ids")    // [{codigo:"5394104",variationId:189091},...]
  publishedAt     DateTime? @map("published_at")
  errorMessage    String?  @map("error_message")       @db.Text

  // Auditoria
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([refCode, cor], name: "uniq_ref_cor")
  @@index([status, createdAt(sort: Desc)])
  @@index([refCode])
  @@map("site_publish_queue")
}

// ═══════════════════════════════════════════════════════════════════════════
// COBRANÇA AUTOMÁTICA — campanhas recorrentes que rodam server-side
// ═══════════════════════════════════════════════════════════════════════════
//
// Diferente do disparo manual (botão "Disparar X mensagens"), aqui a matriz
// cadastra UMA campanha contínua e o cron worker cuida do resto:
//
//   - Roda a cada 5 minutos
//   - Pra cada CobrancaCampanha ativa, valida:
//       1. Janela de horário (horaInicio ≤ agora ≤ horaFim)
//       2. Frequência (proximoEnvio já chegou?)
//       3. Lista de elegíveis (mesma lógica do /preview, com minDiasAtraso)
//       4. Pra cada cliente:
//           - se já recebeu nas últimas N horas → skip
//           - se parcela já foi paga (PAGO=S no movimento) → skip
//           - se opt-out (WaOptOut) → skip
//           - senão → envia + cria CobrancaTentativa
//   - Atualiza ultimoEnvio + proximoEnvio (calcula próximo slot)
//
// Frequências suportadas (string):
//   '1x_dia'      → 1 mensagem por cliente por dia
//   '2x_dia'      → 2 mensagens por dia (manhã + tarde)
//   'cada_2_dias' → 1 mensagem a cada 2 dias
//   'cada_3_dias' → 1 mensagem a cada 3 dias
//   'semanal'     → 1 mensagem por semana
//
// Estado de "cliente já recebeu" — consultado via CobrancaTentativa pelo
// par (campanhaId, codCliente, status='ok', enviadaEm > limite).

model CobrancaCampanha {
  id            String   @id @default(uuid())
  nome          String                              // ex: "Cobrança Loja 01 — vencidos 3+ dias"
  lojaCode      String   @map("loja_code")          // "01", "02", etc
  ativa         Boolean  @default(true)

  // Janela de horário (HH:MM, 24h)
  horaInicio    String   @map("hora_inicio")        // "09:00"
  horaFim       String   @map("hora_fim")           // "18:00"

  // Frequência: 1x_dia | 2x_dia | cada_2_dias | cada_3_dias | semanal
  frequencia    String

  // Filtros de elegibilidade
  minDiasAtraso Int      @default(3) @map("min_dias_atraso")
  maxDiasAtraso Int?     @map("max_dias_atraso")    // opcional — só cobra até N dias

  // Espaçamento entre mensagens (ms) durante o disparo de uma rodada
  delayMs       Int      @default(120000)            // 2min default

  // Estado da campanha (atualizado pelo worker)
  ultimoEnvio   DateTime? @map("ultimo_envio")       // último disparo de batch
  proximoEnvio  DateTime? @map("proximo_envio")      // quando o worker DEVE rodar de novo
  totalEnviadas Int      @default(0) @map("total_enviadas")

  // Auditoria
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tentativas CobrancaTentativa[]

  @@index([ativa, proximoEnvio])
  @@index([lojaCode])
  @@map("cobranca_campanhas")
}

model CobrancaTentativa {
  id          String   @id @default(uuid())
  campanhaId  String   @map("campanha_id")
  codCliente  String   @map("cod_cliente")
  nome        String
  telefone    String                                  // número usado no envio (pode ser teste)
  telefoneOriginal String? @map("telefone_original") // número real do cliente (modo teste)
  templateIndex Int    @map("template_index")
  mensagem    String                                  // texto enviado (pra auditoria)
  status      String                                  // ok | falha | skipped
  erro        String?
  enviadaEm   DateTime @default(now()) @map("enviada_em")

  campanha CobrancaCampanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)

  @@index([campanhaId, codCliente, enviadaEm(sort: Desc)])
  @@index([campanhaId, status, enviadaEm(sort: Desc)])
  @@map("cobranca_tentativas")
}

// ═══════════════════════════════════════════════════════════════════════════
// CREDIÁRIO — Baixa de parcelas direto na loja (cliente vem pagar promissória)
// ═══════════════════════════════════════════════════════════════════════════
//
// Fluxo:
//   1. Cliente vai até a loja e quer pagar parcelas em aberto
//   2. Vendedora bate no PDV → botão RECEBIMENTOS → busca cliente (CPF/nome)
//   3. Sistema lista parcelas em aberto do Gigasistemas (movimento PAGO='N')
//      com juros calculados conforme CrediarioConfig (carência + taxa mensal/30)
//   4. Vendedora seleciona parcelas → escolhe forma pagamento (PIX/dinheiro)
//   5. Confirma → backend faz UPDATE no movimento (PAGO='S' + DATA_PAGAMENTO)
//      e cria registro em CrediarioBaixa+CrediarioBaixaItem (audit local)
//   6. Imprime recibo 80mm não fiscal pra cliente assinar e ir pro caixa físico

model CrediarioConfig {
  id                 String   @id @default("singleton")
  // Após quantos dias do vencimento começa a correr juros (carência).
  // Default 0 = juros desde o 1º dia de atraso.
  diasCarencia       Int      @default(0) @map("dias_carencia")
  // Taxa mensal em porcentagem (ex: 8.0 = 8% ao mês).
  // Calculada DIA-A-DIA: (taxaMensal / 30) por dia em atraso.
  taxaMensalPercent  Float    @default(0) @map("taxa_mensal_percent")
  // Habilitar cobrança de juros? Se false, sempre retorna juros = 0.
  enabled            Boolean  @default(false)
  // Multa fixa (%) aplicada UMA vez ao entrar em atraso (após carência).
  // Padrão BR: 2%. 0 = sem multa. Soma ao juros calculado.
  multaPercent       Float    @default(0) @map("multa_percent")
  // Teto de juros como % do valor da parcela (ex: 100 = juros nunca passa do
  // principal). 0 = sem teto (comportamento legado). Protege de juros que
  // explodem em parcelas muito antigas.
  jurosMaxPercentParcela Float @default(0) @map("juros_max_percent_parcela")
  // ── POLÍTICA DE LIMITE DE CRÉDITO (default OFF — não altera nada até ligar) ──
  // Quando ligada, o PDV bloqueia novo crediário pra cliente acima do limite.
  // O bloqueio pode ser liberado com senha de supervisor (override).
  limiteEnabled            Boolean @default(false) @map("limite_enabled")
  // Máximo de parcelas VENCIDAS em aberto que o cliente pode ter (0 = ignora).
  limiteMaxParcelasVencidas Int    @default(0) @map("limite_max_parcelas_vencidas")
  // Máximo de valor TOTAL em aberto (vencido + a vencer). 0 = ignora.
  limiteMaxValorEmAberto   Float   @default(0) @map("limite_max_valor_em_aberto")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("crediario_config")
}

// Header de uma baixa multi-parcelas
model CrediarioBaixa {
  id                String   @id @default(uuid())
  // Cliente do Giga
  codCliente        String?  @map("cod_cliente")
  customerCpf       String?  @map("customer_cpf")
  customerName      String?  @map("customer_name")
  customerPhone     String?  @map("customer_phone")
  // Loja onde a baixa foi feita (PDV da filial)
  lojaCode          String   @map("loja_code")
  lojaName          String?  @map("loja_name")
  // Vendedora que operou
  userId            String?  @map("user_id")
  userName          String?  @map("user_name")
  // Totais calculados na hora da baixa
  totalParcelas     Int      @default(0) @map("total_parcelas")
  totalPrincipal    Float    @default(0) @map("total_principal")
  totalJuros        Float    @default(0) @map("total_juros")
  totalPago         Float    @default(0) @map("total_pago")
  // Forma de pagamento usada
  formaPagamento    String                              // pix | dinheiro | misto (split dinheiro+pix)
  // Origem do PIX: 'presencial' (QR loja, cliente la) ou 'link' (WhatsApp remoto).
  // Usado pra decidir se mostra alerta global "PIX recebido" — so link remoto
  // mostra alerta (presencial a vendedora ja ve o cliente pagar). Null pra
  // dinheiro/misto/null antigos.
  origem            String?  @map("origem")
  // Split: quando formaPagamento='misto', cliente paga parte em dinheiro
  // e parte em PIX. valorDinheiro entra no caixa direto; valorPix gera QR
  // Pagar.me e fica pending ate confirmacao.
  valorDinheiro     Float?   @map("valor_dinheiro")
  valorPix          Float?   @map("valor_pix")
  // Quando PIX, vincula com a order Pagar.me
  pagarmeOrderId    String?  @unique @map("pagarme_order_id")
  // Status: pending (PIX não pago ainda) | paid (confirmado) | canceled
  status            String   @default("paid")
  paidAt            DateTime? @map("paid_at")
  // Estorno — quando uma baixa precisa ser desfeita (cliente pediu, pagamento por engano, etc)
  canceledAt        DateTime? @map("canceled_at")
  canceledByUserId  String?   @map("canceled_by_user_id")
  canceledByUserName String?  @map("canceled_by_user_name")
  canceledReason    String?   @map("canceled_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  items             CrediarioBaixaItem[]

  @@index([lojaCode, createdAt(sort: Desc)])
  @@index([codCliente, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("crediario_baixas")
}

// Item de baixa: uma parcela do movimento Giga
model CrediarioBaixaItem {
  id              String   @id @default(uuid())
  baixaId         String   @map("baixa_id")
  // Identificação da parcela no Giga (REGISTRO + CONTROLE = chave composta)
  registro        String                                // movimento.REGISTRO
  controle        String                                // movimento.CONTROLE
  numeroPromis    String?  @map("numero_promis")        // exibição (NUMERO_COMPRA + parcela)
  parcelaNum      Int?     @map("parcela_num")
  totalParcelas   Int?     @map("total_parcelas")
  vencimento      DateTime
  valorParcela    Float    @map("valor_parcela")
  jurosCalculado  Float    @default(0) @map("juros_calculado")
  diasAtraso      Int      @default(0) @map("dias_atraso")
  valorPago       Float    @map("valor_pago")           // valorParcela + jurosCalculado
  // Resultado do UPDATE no Giga (audit)
  gigaUpdateOk    Boolean  @default(false) @map("giga_update_ok")
  gigaError       String?  @map("giga_error") @db.Text

  baixa           CrediarioBaixa @relation(fields: [baixaId], references: [id], onDelete: Cascade)

  @@index([baixaId])
  @@index([registro, controle])
  @@map("crediario_baixa_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// PDV — Frente de caixa (substituição gradual do Gigasistemas)
// ═══════════════════════════════════════════════════════════════════════════
//
// Modelo simples pra MVP:
//   - PdvSale = cabeçalho (loja, vendedora, cliente opcional, total, pagamento)
//   - PdvSaleItem = item do carrinho (snapshot de tudo: SKU, REF, descrição, NCM, preço)
//
// Snapshot é IMPORTANTE — o produto pode ter preço/descrição alterada depois,
// mas a venda preserva o que foi vendido naquele momento.
//
// Status: open (montando) → finalized (paga) | cancelled
//
// NFC-e fica como string XML (pra debug/preview). Quando integrar com SEFAZ
// real, vira o XML assinado. Por enquanto é "stub" pra mostrar o que sairia.
//
model PdvSale {
  id              String   @id @default(uuid())
  // Loja origem da venda
  storeCode       String   @map("store_code")
  storeName       String   @map("store_name")
  // Caixa em que essa venda foi feita (FK lógica — sem cascade pra preservar histórico)
  cashSessionId   String?  @map("cash_session_id")
  // Vendedora (opcional — pode ser auto preenchido pelo JWT)
  vendedorUserId  String?  @map("vendedor_user_id")
  vendedorName    String?  @map("vendedor_name")
  // Vendedora atribuída pra comissão (FK Seller — separado do user que digitou)
  sellerId        String?  @map("seller_id")
  sellerName      String?  @map("seller_name")
  // Cliente (opcional — venda no balcão pode ser sem CPF)
  customerCpf     String?  @map("customer_cpf")
  customerName    String?  @map("customer_name")
  customerEmail   String?  @map("customer_email")
  customerPhone   String?  @map("customer_phone")
  // Endereço de entrega (essencial pra vendas online: WhatsApp/Instagram).
  // Opcional pra balcão. Preenchido manualmente ou via lookup ViaCEP no front.
  customerCep         String?  @map("customer_cep")
  customerEndereco    String?  @map("customer_endereco")    // logradouro
  customerNumero      String?  @map("customer_numero")
  customerComplemento String?  @map("customer_complemento")
  customerBairro      String?  @map("customer_bairro")
  customerCidade      String?  @map("customer_cidade")
  customerUf          String?  @map("customer_uf")
  // Status + valores
  status          String   @default("open")
  subtotal        Float    @default(0)
  desconto        Float    @default(0)
  total           Float    @default(0)
  // Campanha promocional ATIVA (exclusiva — uma de cada vez)
  // Valores: 'YEAR_BASED' | 'FOUR_FOR_THREE' | 'NONE' (default)
  activePromotion String?  @map("active_promotion")
  // Pagamento
  paymentMethod   String?  @map("payment_method")
  paymentDetails  String?  @map("payment_details")
  // Fiscal
  nfceStatus      String?  @map("nfce_status")
  nfceNumber      String?  @map("nfce_number")
  nfceSerie       String?  @map("nfce_serie")
  nfceChave       String?  @map("nfce_chave")
  nfceXml         String?  @map("nfce_xml") @db.Text
  nfcePdfUrl      String?  @map("nfce_pdf_url")
  // Pós-emissão SEFAZ
  nfceProtocolo   String?  @map("nfce_protocolo")
  nfceMotivo      String?  @map("nfce_motivo") @db.Text
  nfceQrUrl       String?  @map("nfce_qr_url") @db.Text
  nfceUrlConsulta String?  @map("nfce_url_consulta")
  nfceAutorizadaEm DateTime? @map("nfce_autorizada_em")
  // Cancelamento NFC-e (evento 110111)
  nfceCanceladaEm        DateTime? @map("nfce_cancelada_em")
  nfceCancelamentoProto  String?   @map("nfce_cancelamento_proto")
  nfceCancelamentoMotivo String?   @map("nfce_cancelamento_motivo") @db.Text
  nfceCancelamentoXml    String?   @map("nfce_cancelamento_xml") @db.Text
  // Envio
  sentEmailAt     DateTime? @map("sent_email_at")
  sentWhatsappAt  DateTime? @map("sent_whatsapp_at")
  // Vinculo com sistema de MARCADOS (provar em casa). Quando a venda foi
  // criada via "Puxar pra venda" da tela /pdv/marcados, guarda os REGISTROs
  // do Wincred caixa que originaram os itens. Ao finalizar a venda, esses
  // marcados devem ser fechados (DELETE/UPDATE MARCADO='NAO' no Wincred).
  marcadosRegistros String?  @map("marcados_registros") @db.Text
  // Flag de idempotencia: timestamp do momento em que o estoque Wincred foi
  // baixado pra essa venda. Quando NULL, o script de reconciliacao retroativa
  // sabe que precisa rodar decreaseStock pra essa venda. Quando preenchido,
  // pula (ja foi baixado). Marcado automaticamente no finalize() quando a
  // baixa de estoque sucede.
  stockDecreasedAt  DateTime? @map("stock_decreased_at")
  // ── Conciliação Stone (maquininha) — webhook bate aqui ──
  stoneConciliatedAt DateTime? @map("stone_conciliated_at")
  stoneTxId          String?   @map("stone_tx_id")           // transaction_id da Stone
  stoneNsu           String?   @map("stone_nsu")             // NSU/autorização
  stoneBandeira      String?   @map("stone_bandeira")        // VISA, MASTER, etc
  stoneLast4         String?   @map("stone_last4")           // últimos 4 dígitos do cartão
  // ── CREDIÁRIO (idempotência) ──
  // CONTROLE retornado pelo Giga quando as parcelas foram criadas. Serve de
  // trava: se já preenchido, o endpoint POST /crediario NÃO recria parcelas
  // (evita duplicação por retry de rede, duplo-clique ou os 2 fluxos do front).
  crediarioControle  String?   @map("crediario_controle")
  crediarioCriadoEm  DateTime? @map("crediario_criado_em")
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  finalizedAt     DateTime? @map("finalized_at")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelReason    String?  @map("cancel_reason")

  // ── MODO TREINAMENTO ──
  // Quando true: venda não decrementou estoque, não chamou Giga, não emitiu NFC-e.
  // Não conta em relatórios financeiros nem conciliação. Existe só pra histórico
  // do treinamento (quem praticou, quando, o quê).
  isTraining      Boolean  @default(false) @map("is_training")

  items           PdvSaleItem[]
  payments        PdvSalePayment[]

  @@index([storeCode, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  // Comissões, relatório diário e fiscal filtram/ordenam por finalizedAt (não
  // createdAt). Sem este índice, cada cálculo varria pdv_sales inteira.
  @@index([status, finalizedAt(sort: Desc)])
  @@index([customerCpf])
  @@index([cashSessionId])
  @@index([sellerId])
  @@index([stoneTxId])
  @@index([isTraining])
  @@map("pdv_sales")
}

// ═══════════════════════════════════════════════════════════════════════
// CONCILIAÇÃO STONE — transações da maquininha
// ═══════════════════════════════════════════════════════════════════════
// Cada webhook recebido da Stone vira 1 linha aqui. Se conseguimos casar
// com uma PdvSale, marca matchedSaleId. Se não, fica "órfã" pra revisão.
model StoneTransaction {
  id               String   @id @default(uuid())
  // Identificadores Stone
  stoneTxId        String   @unique @map("stone_tx_id")
  stoneNsu         String?  @map("stone_nsu")
  authorizationCode String? @map("authorization_code")
  // Valores/dados do pagamento
  amount           Float                                  // em reais (centavos / 100)
  paymentMethod    String?  @map("payment_method")        // credit_card | debit_card | pix
  bandeira         String?                                // VISA, MASTER, etc (null pra PIX)
  last4            String?  @map("last4")                 // null pra PIX
  installments     Int?     @default(1)                   // 1 pra PIX
  // Origem na maquininha
  merchantId       String?  @map("merchant_id")
  storeCode        String?  @map("store_code")           // resolvido via merchantId
  // Status
  status           String   @default("captured")          // captured | refunded | denied
  capturedAt       DateTime @map("captured_at")
  // Conciliação com PdvSale
  matchedSaleId    String?  @map("matched_sale_id")       // FK lógica (sem cascade)
  matchedAt        DateTime? @map("matched_at")
  matchScore       Int?     @map("match_score")           // 0-100, qualidade do match
  matchReason      String?  @map("match_reason")          // exact, fuzzy_time, manual
  // Payload bruto pra auditoria
  rawPayload       String   @map("raw_payload") @db.Text
  receivedAt       DateTime @default(now()) @map("received_at")

  @@index([capturedAt(sort: Desc)])
  @@index([matchedSaleId])
  @@index([storeCode, capturedAt(sort: Desc)])
  @@index([status])
  @@map("stone_transactions")
}

// ═══════════════════════════════════════════════════════════════════════
// CAIXA DIÁRIO — abertura/fechamento + sangria/suprimento
// ═══════════════════════════════════════════════════════════════════════

// Sessão de caixa = "dia da loja". Vendedora abre com fundo de troco,
// faz vendas durante o dia, registra sangrias/suprimentos, e fecha com
// conferência (físico vs sistema). Só pode haver UMA sessão `open` por loja
// por vez (índice parcial não é suportado em todos os DBs, então a regra
// é validada na app — buscar `where status=open AND storeCode=X`).
model PdvCashSession {
  id              String   @id @default(uuid())
  storeCode       String   @map("store_code")
  storeName       String   @map("store_name")
  // Quem abriu (vendedora/operadora)
  openedByUserId  String?  @map("opened_by_user_id")
  openedByName    String?  @map("opened_by_name")
  // Status: open | closed
  status          String   @default("open")
  // Valores de abertura
  fundoTroco      Float    @default(0) @map("fundo_troco")     // dinheiro inicial pra troco
  // Snapshot calculado no fechamento (pra histórico — não recalcular sempre)
  totalVendas         Float?   @map("total_vendas")
  totalDinheiro       Float?   @map("total_dinheiro")           // soma payments dinheiro
  totalPix            Float?   @map("total_pix")
  totalCartaoCredito  Float?   @map("total_cartao_credito")
  totalCartaoDebito   Float?   @map("total_cartao_debito")
  totalCrediario      Float?   @map("total_crediario")
  totalSangrias       Float?   @map("total_sangrias")           // saídas
  totalSuprimentos    Float?   @map("total_suprimentos")        // reforços
  // Conferência física no fechamento
  dinheiroEsperado    Float?   @map("dinheiro_esperado")        // fundo + dinheiro - sangrias + suprimentos
  dinheiroFisico      Float?   @map("dinheiro_fisico")          // o que a vendedora contou
  diferenca           Float?   // físico - esperado
  observacao      String?  @db.Text
  // Timestamps
  openedAt        DateTime @default(now()) @map("opened_at")
  closedAt        DateTime? @map("closed_at")
  closedByName    String?  @map("closed_by_name")
  // Conferência manual: CEO/admin bate caixa do dia anterior contra Wincred
  // e marca como conferido. Independente do fechamento operacional.
  checkedAt       DateTime? @map("checked_at")
  checkedByUserId String?   @map("checked_by_user_id")
  checkedByName   String?   @map("checked_by_name")
  checkedNote     String?   @map("checked_note") @db.Text

  // ── MODO TREINAMENTO ──
  isTraining      Boolean  @default(false) @map("is_training")

  movements       PdvCashMovement[]

  @@index([storeCode, status])
  @@index([storeCode, openedAt(sort: Desc)])
  @@index([isTraining])
  @@map("pdv_cash_sessions")
}

// Sangria (saída) ou Suprimento (entrada) DURANTE a sessão.
// NÃO inclui pagamentos de venda — esses ficam em PdvSalePayment.
model PdvCashMovement {
  id            String   @id @default(uuid())
  cashSessionId String   @map("cash_session_id")
  // tipo: 'sangria' (saída) | 'suprimento' (entrada)
  tipo          String
  valor         Float
  motivo        String   @db.Text
  // Quem registrou
  userId        String?  @map("user_id")
  userName      String?  @map("user_name")
  createdAt     DateTime @default(now()) @map("created_at")

  // ── MODO TREINAMENTO ──
  isTraining    Boolean  @default(false) @map("is_training")

  session       PdvCashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([cashSessionId])
  @@index([tipo])
  @@index([isTraining])
  @@map("pdv_cash_movements")
}

// ═══════════════════════════════════════════════════════════════════════
// DEVOLUÇÃO / TROCA
// ═══════════════════════════════════════════════════════════════════════

// Devolução de venda finalizada. 3 modos:
//   - dinheiro: gera sangria automática + estorna estoque
//   - troca:    gera vale-troca (PdvCashMovement crédito) e cliente usa em nova venda
//   - credito:  vale-troca com prazo de validade
//
// Sempre estorna estoque no Giga (increaseStock) das peças retornadas.
model PdvReturn {
  id              String   @id @default(uuid())
  // Venda original — NULL pra devoluções manuais (peça vendida no Giga
  // antigo, sem cupom flowops). Source identifica a origem.
  originalSaleId  String?  @map("original_sale_id")
  originalSaleNumber String? @map("original_sale_number")
  // Origem: 'flowops' (venda do PDV novo, com originalSaleId) ou
  // 'giga_manual' (peça do Giga sem cupom). Default flowops.
  source          String   @default("flowops")
  // SKU bipado direto (preenchido pra devoluções manuais — não tem item original)
  manualSku       String?  @map("manual_sku")
  // Loja onde foi feita a devolução
  storeCode       String   @map("store_code")
  storeName       String   @map("store_name")
  cashSessionId   String?  @map("cash_session_id")  // sessão de caixa atual
  // Modo: 'dinheiro' | 'troca' | 'credito'
  modo            String
  valorTotal      Float    @map("valor_total")
  // Status: 'pending' | 'completed' | 'used' (pra credito quando consumido)
  status          String   @default("completed")
  // Cliente
  customerCpf     String?  @map("customer_cpf")
  customerName    String?  @map("customer_name")
  // Crédito gerado (se modo=credito ou troca)
  creditoCode     String?  @unique @map("credito_code")  // código de barras do vale (ex: TROCA-XXXXX)
  creditoValidade DateTime? @map("credito_validade")
  creditoUsadoEm  String?  @map("credito_usado_em")      // saleId onde foi consumido
  creditoUsadoAt  DateTime? @map("credito_usado_at")
  // Quem fez
  userId          String?  @map("user_id")
  userName        String?  @map("user_name")
  motivo          String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  // ── MODO TREINAMENTO ──
  isTraining     Boolean  @default(false) @map("is_training")

  items           PdvReturnItem[]

  @@index([originalSaleId])
  @@index([storeCode, createdAt(sort: Desc)])
  @@index([customerCpf])
  @@index([status])
  @@index([isTraining])
  @@map("pdv_returns")
}

// ═══════════════════════════════════════════════════════════════════════
// PAGAR.ME — config global + rastreio de pagamentos PIX
// ═══════════════════════════════════════════════════════════════════════
//
// Pagar.me API v5 (https://api.pagar.me/core/v5).
// Auth: Basic com API Key + senha vazia → header `Authorization: Basic <b64>`.
// PIX dinâmico funciona em produção SEM homologação prévia (vantagem
// principal sobre PagBank). Cada Order tem `payments[].pix.qr_code` +
// `qr_code_url` (texto copia-e-cola + URL da imagem).
model PagarmeConfig {
  id              String   @id @default("singleton")
  // Ambiente: 'test' (sandbox) | 'live' (produção)
  ambiente        String   @default("test")
  // API Key Pagar.me (formato: sk_xxxxx pra produção, sk_test_xxxxx pra sandbox)
  apiKey          String?  @map("api_key") @db.Text
  // Webhook secret pra validar HMAC dos eventos
  webhookSecret   String?  @map("webhook_secret")
  // Recipient ID (formato: rp_xxx ou ba_xxx) — obrigatório quando conta é PSP/marketplace.
  // Quando preenchido, o service injeta split rule de 100% pra esse recebedor em todo charge.
  recipientId     String?  @map("recipient_id")
  // Habilitado? Se false, PDV cai no fallback PIX local
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pagarme_config")
}

/// Config Pagar.me por loja. Cada loja com CNPJ proprio pode ter sua conta
/// Pagar.me e API key independente. Se nao cadastrar, usa o singleton
/// PagarmeConfig como fallback (mesma logica do PagbankStoreConfig).
///
/// Resolucao no PDV: PagarmeStoreConfig WHERE storeCode = X AND enabled = true
///   -> fallback: PagarmeConfig singleton
model PagarmeStoreConfig {
  storeCode       String   @id @map("store_code")
  ambiente        String   @default("test")
  apiKey          String?  @map("api_key") @db.Text
  webhookSecret   String?  @map("webhook_secret")
  recipientId     String?  @map("recipient_id")
  enabled         Boolean  @default(false)
  // Identificacao visual: razao social ou nome curto da conta Pagar.me
  contaLabel      String?  @map("conta_label") @db.VarChar(80)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pagarme_store_config")
}

// Cada cobrança PIX vira um registro aqui.
model PagarmePayment {
  id              String   @id @default(uuid())
  saleId          String   @map("sale_id")
  storeCode       String   @map("store_code")
  // Order Pagar.me
  pagarmeOrderId  String   @unique @map("pagarme_order_id")
  pagarmeChargeId String?  @map("pagarme_charge_id")
  method          String   @default("pix")
  valor           Float
  status          String   @default("pending")  // pending | paid | failed | canceled
  qrCodeText      String?  @map("qr_code_text") @db.Text
  qrCodeImageUrl  String?  @map("qr_code_image_url") @db.Text
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  paidAt          DateTime? @map("paid_at")
  rawWebhook      String?  @map("raw_webhook") @db.Text

  @@index([saleId])
  @@index([status, createdAt(sort: Desc)])
  @@map("pagarme_payments")
}

// ═══════════════════════════════════════════════════════════════════════
// PAGBANK — config global + rastreio de pagamentos PIX/cartão
// ═══════════════════════════════════════════════════════════════════════
//
// Como a Lurd's tem CONTA ÚNICA PagBank (CNPJ matriz), config é global
// (não por loja). Todo dinheiro cai na mesma conta — depois conciliamos
// por loja via reference_id da Order (que carrega storeCode da venda).
model PagbankConfig {
  id              String   @id @default("singleton")
  // Ambiente: 'sandbox' | 'production'
  ambiente        String   @default("sandbox")
  // E-mail cadastrado no PagSeguro/PagBank (necessário pra alguns endpoints clássicos)
  email           String?
  // Bearer Token (sandbox ou prod) — guardado as-is (não exibido no GET)
  bearerToken     String?  @map("bearer_token") @db.Text
  // Webhook secret pra validar assinatura HMAC dos POST recebidos
  webhookSecret   String?  @map("webhook_secret")
  // Habilitado? Se false, PDV cai no fallback PIX local
  enabled         Boolean  @default(false)
  // Auditoria
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pagbank_config")
}

/// Config PagBank por loja. Cada loja com CNPJ proprio tem sua conta PagBank
/// e token independente. Se nao cadastrar, usa o singleton PagbankConfig
/// como fallback. Permite migracao gradual (matriz primeiro, lojas depois).
///
/// Quando o PDV cria PIX, o backend resolve config nesta ordem:
///   1. PagbankStoreConfig WHERE storeCode = X AND enabled = true
///   2. fallback: PagbankConfig singleton
model PagbankStoreConfig {
  storeCode       String   @id @map("store_code")
  ambiente        String   @default("production")
  email           String?
  bearerToken     String?  @map("bearer_token") @db.Text
  webhookSecret   String?  @map("webhook_secret")
  enabled         Boolean  @default(false)
  // Identificacao visual: razao social ou nome curto da conta PagBank
  // (ajuda admin lembrar qual conta esta vinculada a essa loja)
  contaLabel      String?  @map("conta_label") @db.VarChar(80)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pagbank_store_config")
}

// Cada cobrança PIX gerada vira um registro aqui pra rastrear status.
// Vinculada à PdvSalePayment (split payment) — quando webhook chega
// confirmando, o payment é marcado como pago e a venda finaliza.
model PagbankPayment {
  id              String   @id @default(uuid())
  // Vínculo com a venda PDV
  saleId          String   @map("sale_id")
  pdvPaymentId    String?  @map("pdv_payment_id")  // FK pra PdvSalePayment
  storeCode       String   @map("store_code")
  // Order PagBank
  pagbankOrderId  String   @unique @map("pagbank_order_id")
  pagbankChargeId String?  @map("pagbank_charge_id")
  // Tipo: 'pix' | 'credit_card' | 'boleto'
  method          String
  valor           Float
  // Status: pending | paid | expired | cancelled | failed
  status          String   @default("pending")
  // PIX
  qrCodeText      String?  @map("qr_code_text") @db.Text   // copia-e-cola
  qrCodeImageB64  String?  @map("qr_code_image_b64") @db.Text  // PNG base64
  expiresAt       DateTime? @map("expires_at")
  // Auditoria
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  paidAt          DateTime? @map("paid_at")
  rawWebhook      String?  @map("raw_webhook") @db.Text

  @@index([saleId])
  @@index([status, createdAt(sort: Desc)])
  @@index([pagbankOrderId])
  @@map("pagbank_payments")
}

// ═══════════════════════════════════════════════════════════════════════
// TROCA DE PEDIDO DO SITE (WC) — peça volta pro estoque da loja receptora
// ═══════════════════════════════════════════════════════════════════════
//
// Cliente do site recebe peça → arrepende, defeito, tamanho errado → manda
// de volta → loja física recebe → registra essa troca no sistema → estoque
// volta pro Giga (loja que recebeu fisicamente a peça).
//
// Diferente de PdvReturn (devolução de venda balcão), aqui a venda original
// foi pelo site e o estoque já saiu lá atrás (loja que separou). Pode voltar
// pra UMA loja diferente (a mais perto do cliente, etc).
model WcReturnRequest {
  id                String   @id @default(uuid())
  // Pedido WC original
  wcOrderId         Int      @map("wc_order_id")
  wcOrderNumber     String?  @map("wc_order_number")
  // Cliente snapshot
  customerName      String?  @map("customer_name")
  customerCpf       String?  @map("customer_cpf")
  customerEmail     String?  @map("customer_email")
  // Loja que está recebendo a peça FÍSICA (pra estornar pro Giga dela)
  receivingStoreCode String  @map("receiving_store_code")
  receivingStoreName String  @map("receiving_store_name")
  // Modo: 'devolucao' (estorna $) | 'troca' (gera vale) | 'credito' (vale com prazo)
  modo              String
  valorTotal        Float    @map("valor_total")
  status            String   @default("completed")  // pending | completed | cancelled
  // Snapshot info do prazo no momento do registro
  diasDesdeEnvio    Int?     @map("dias_desde_envio")
  dentroDoPrazo     Boolean? @map("dentro_do_prazo")
  // Vale (se modo = troca/credito)
  creditoCode       String?  @unique @map("credito_code")
  creditoValidade   DateTime? @map("credito_validade")
  creditoUsadoEm    String?  @map("credito_usado_em")
  creditoUsadoAt    DateTime? @map("credito_usado_at")
  // Operadora
  userId            String?  @map("user_id")
  userName          String?  @map("user_name")
  motivo            String?  @db.Text
  obs               String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  items             WcReturnRequestItem[]

  @@index([wcOrderId])
  @@index([receivingStoreCode, createdAt(sort: Desc)])
  @@index([customerCpf])
  @@index([status])
  @@map("wc_return_requests")
}

model WcReturnRequestItem {
  id                String   @id @default(uuid())
  returnRequestId   String   @map("return_request_id")
  sku               String
  productName       String?  @map("product_name")
  qty               Int      @default(1)
  precoUnit         Float    @map("preco_unit")
  total             Float
  // Status estorno Giga
  stockReturnedAt   DateTime? @map("stock_returned_at")
  stockError        String?   @map("stock_error")
  createdAt         DateTime @default(now()) @map("created_at")

  request           WcReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([sku])
  @@map("wc_return_request_items")
}

// ═══════════════════════════════════════════════════════════════════════
// NFC-e CONFIG POR LOJA
// ═══════════════════════════════════════════════════════════════════════
//
// Cada loja tem seu próprio CNPJ, IE, CSC e (geralmente) certificado A1.
// O PDV emite a NFC-e usando a config da loja onde a venda foi feita.
//
// O certificado A1 (PFX) e a senha são guardados em base64 — em produção,
// é fortemente recomendado usar criptografia at-rest no banco (Postgres
// pgcrypto ou criptografia da app).
model NfceConfig {
  id              String   @id @default(uuid())
  storeCode       String   @unique @map("store_code")
  storeName       String?  @map("store_name")
  // Ambiente: '1' produção · '2' homologação
  ambiente        String   @default("2")
  uf              String   @default("SP")
  cnpj            String?
  razaoSocial     String?  @map("razao_social")
  fantasia        String?
  ie              String?
  // Regime: '1' Simples Nacional · '3' Regime Normal
  regime          String   @default("1")
  // Endereço (JSON: {logradouro,numero,bairro,municipio,cep,uf,codMunicipio})
  endereco        String?  @db.Text
  // CSC SEFAZ
  cscId           String?  @map("csc_id")
  cscToken        String?  @map("csc_token") @db.Text
  // Numeração
  serie           String   @default("1")
  numeroAtual     Int      @default(0) @map("numero_atual")
  // Certificado A1
  certPfxB64      String?  @map("cert_pfx_b64") @db.Text
  certPfxPass     String?  @map("cert_pfx_pass")
  // Auditoria
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("nfce_configs")
}

model PdvReturnItem {
  id              String   @id @default(uuid())
  returnId        String   @map("return_id")
  // Snapshot da peça devolvida
  originalItemId  String?  @map("original_item_id")
  sku             String
  ref             String?
  cor             String?
  tamanho         String?
  descricao       String
  qty             Int      @default(1)
  precoUnit       Float    @map("preco_unit")
  total           Float
  // Estorno de estoque Giga
  stockReturnedAt DateTime? @map("stock_returned_at")
  stockError      String?  @map("stock_error")
  createdAt       DateTime @default(now()) @map("created_at")

  return          PdvReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([sku])
  @@map("pdv_return_items")
}

// Pagamentos individuais de uma venda (split payment).
// Uma venda pode ter N pagamentos (ex: dinheiro + cartão + PIX).
// Soma de payments.valor deve igualar PdvSale.total pra venda finalizar.
model PdvSalePayment {
  id        String   @id @default(uuid())
  saleId    String   @map("sale_id")
  method    String                                  // dinheiro | pix | credito | debito | crediario
  valor     Float
  details   String?  @db.Text                       // JSON: bandeira, parcelas, troco, txid, etc
  createdAt DateTime @default(now()) @map("created_at")

  sale      PdvSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("pdv_sale_payments")
}

// Auditoria de ajustes em pagamentos.
// Toda alteração feita por supervisor/admin via PATCH em pagamento gera 1 row aqui.
// Imutável (insert-only) — registro de quem mudou, quando, valores antes/depois e razão.
model PdvPaymentAudit {
  id                String   @id @default(uuid())
  paymentId         String   @map("payment_id")
  saleId            String   @map("sale_id")
  oldMethod         String   @map("old_method")
  oldValor          Float    @map("old_valor")
  oldDetails        String?  @map("old_details") @db.Text
  newMethod         String   @map("new_method")
  newValor          Float    @map("new_valor")
  newDetails        String?  @map("new_details") @db.Text
  changedByUserId   String?  @map("changed_by_user_id")
  changedByUserName String?  @map("changed_by_user_name")
  changedByRole     String?  @map("changed_by_role")
  reason            String   @db.Text
  changedAt         DateTime @default(now()) @map("changed_at")

  @@index([paymentId, changedAt(sort: Desc)])
  @@index([saleId, changedAt(sort: Desc)])
  @@map("pdv_payment_audits")
}

model PdvSaleItem {
  id          String   @id @default(uuid())
  saleId      String   @map("sale_id")
  // Snapshot do produto Giga
  sku         String
  ean         String?
  ref         String?
  cor         String?
  tamanho     String?
  descricao   String
  ncm         String?
  cfop        String?
  dataCadastro String? @map("data_cadastro")     // YYYY-MM-DD do cadastro Giga (pra promoções por ano)
  // Quantidades + valores
  qty         Int      @default(1)
  precoUnit   Float    @map("preco_unit")
  desconto    Float    @default(0)
  promoTag    String?  @map("promo_tag")         // ex: "PROMO 30% · 2022" ou "4 LEVA 3"
  total       Float
  // Override de vendedora POR ITEM. NULL = usa sale.sellerName (padrao).
  // Usado quando 2 vendedoras atendem na mesma compra — uma operou tudo
  // e depois a comissao eh dividida item por item.
  sellerName  String?  @map("seller_name")
  createdAt   DateTime @default(now()) @map("created_at")

  sale        PdvSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([sku])
  @@index([ref])
  @@index([ean])
  @@map("pdv_sale_items")
}

// ════════════════════════════════════════════════════════════════
// MasterAudit — log de toda acao master (ajustes pos-fato pelo painel).
// Registra QUEM (level + userName), O QUE mudou (action + entity + ids),
// VALORES (old/new em JSON) e MOTIVO. Imutavel apos criacao.
// ════════════════════════════════════════════════════════════════
model MasterAudit {
  id          String   @id @default(uuid())
  // 'sale_seller' | 'item_seller' | 'fundo' | 'movement_create' | 'movement_delete' | 'payment_edit'
  action      String
  // 'sale' | 'sale_item' | 'session' | 'movement' | 'payment'
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  storeCode   String?  @map("store_code")
  storeName   String?  @map("store_name")
  // Nivel da senha digitada: SUPREMA | MASTER | GERENTE | SUPERVISOR | CAIXA
  level       String
  // Quem estava logado (do JWT)
  userName    String   @map("user_name")
  // Snapshot do ANTES e DEPOIS (JSON serializado)
  oldValue    String?  @map("old_value") @db.Text
  newValue    String?  @map("new_value") @db.Text
  motivo      String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // ── MODO TREINAMENTO ──
  isTraining  Boolean  @default(false) @map("is_training")

  @@index([action])
  @@index([entityType, entityId])
  @@index([storeCode])
  @@index([createdAt])
  @@index([isTraining])
  @@map("master_audits")
}

// ════════════════════════════════════════════════════════════════
// Product Registration — sequência de EAN-13 (prefixo 8) usada pelo
// Cadastro Dinâmico de Produtos (/retaguarda/cadastro-produtos).
// Cada novo produto pega o próximo seq, monta EAN-13 com check digit
// e grava na tabela `produtos` do Wincred (gigasistemas21).
// Single row (id=1). Atualizada em transação a cada batch.
// ════════════════════════════════════════════════════════════════
model EanSequence {
  id        Int      @id @default(autoincrement())
  prefix    String   @default("8")
  lastSeq   BigInt   @default(0) @map("last_seq")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ean_sequence")
}

// ═══════════════════════════════════════════════════════════════════════
// Size Feedback — review por tamanho real ("Cabe em quem veste 48?")
//
// Coletado D+7 após a entrega via push/banner in-app. Cliente diz como
// serviu a peça que comprou. Exibido na página de produto pra ajudar
// outras clientes a escolher o tamanho certo. Mata a maior dúvida do plus:
// "vai servir em mim?". Compromisso de confiança — não falsificar dados.
//
// Exemplo de query agregada (na página do produto, tamanho selecionado=48):
//   SELECT feedback, COUNT(*) FROM size_feedback
//   WHERE product_id=X AND size_usually='48' GROUP BY feedback;
// ═══════════════════════════════════════════════════════════════════════
model SizeFeedback {
  id           String   @id @default(uuid())
  customerId   String   @map("customer_id")      // CustomerAccount.id
  productId    Int      @map("product_id")        // WC product_id
  variationId  Int?     @map("variation_id")      // WC variation_id (se variable)
  orderId      Int?     @map("order_id")          // WC order onde comprou (audit)
  sizeBought   String   @map("size_bought")       // ex: "48"
  sizeUsually  String?  @map("size_usually")      // tamanho que cliente costuma vestir
  feedback     String                              // 'fits' | 'tight' | 'loose' | 'returned'
  comment      String?                             // opcional, free text
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([productId, sizeUsually])               // pra agregação rápida na página produto
  @@index([customerId])                            // pra histórico da cliente
  @@unique([customerId, productId, variationId])   // 1 review por produto/variação
  @@map("size_feedback")
}

// ═══════════════════════════════════════════════════════════════════════
// LIVE OS — Live commerce no Instagram
// ═══════════════════════════════════════════════════════════════════════

// ===========================================================================
// Customer - MESTRE DE CLIENTES DO CRM.
//
// Historico: inicialmente esse model era usado SO pra Lives do Instagram.
// Em 2026-05 expandido pra ser o cliente UNIFICADO da casa:
//   - Loja fisica (origem Giga ou cadastro PDV novo)
//   - E-commerce (WooCommerce / Tray / etc)
//   - Instagram Lives
//   - Cashback + LGPD + perfil Plus Size
//
// IMPORTANTE: a tela /clientes ainda agrega clientes pelos pedidos (Order),
// porque o sync ETL pra popular Customer roda em fase posterior. Quando o ETL
// estiver completo, customers.service passa a usar essa tabela como fonte.
// ===========================================================================
model Customer {
  id              String   @id @default(uuid())

  // -- Identificacao fiscal / Giga --
  // CPF NÃO é mais @unique (jun/2026): mesma pessoa pode ter cadastro em
  // múltiplas lojas físicas (regra do Giga). Cada (loja, codigo) Giga vira
  // 1 Customer separado. Filtro por loja em /clientes-crm fica fiel ao Giga.
  // Pra deduplica de marketing, use personKey (abaixo) + group by.
  cpf             String?
  registroGiga    Int?     @map("registro_giga")
  rg              String?
  rgExp           String?  @map("rg_exp")
  rgEmissao       DateTime? @map("rg_emissao") @db.Date

  // -- Chave de PESSOA (Caminho C) --
  // Identificador único da pessoa real (não confundir com Customer.id que é
  // identificador do cadastro/conta). Múltiplos Customers com mesmo personKey
  // = mesma pessoa em canais/lojas diferentes (WC + Giga loja A + Giga loja B).
  // Hierarquia: cpf (digits) → email → hash(nome+nascimento).
  personKey       String?  @map("person_key")

  // -- Dados basicos --
  name            String?
  nameSocial      String?  @map("name_social")
  email           String?  @unique
  phone           String?
  whatsapp        String?
  birthDate       DateTime? @map("birth_date") @db.Date
  gender          String?
  maritalStatus   String?  @map("marital_status")

  // -- Instagram (mantido pra Lives) --
  igUserId        String?  @unique @map("ig_user_id")
  igUsername      String?  @map("ig_username")
  // ID do assinante no ManyChat (vem no &sid= do link de cadastro da live).
  // Base do envio automático de DM (cobrança em massa via API ManyChat).
  manychatSubscriberId String? @map("manychat_subscriber_id")

  // -- Perfil Plus Size --
  sizeDefault     String?  @map("size_default")
  sizeSecondary   String?  @map("size_secondary")
  bodyType        String?  @map("body_type")
  preferredStyle  String?  @map("preferred_style")
  favoriteColors  String?  @map("favorite_colors")
  avoidedPieces   String?  @map("avoided_pieces")

  // -- Atribuicao / origem --
  originSource    String?  @map("origin_source")
  // Carimbo de quando a pessoa se CADASTROU por uma live (link ManyChat).
  // Independe de createdAt/origin: cliente que já existe na base também é
  // marcada aqui a cada cadastro, pra aparecer na fila "Cadastradas na live".
  liveRegisteredAt DateTime? @map("live_registered_at")
  originStoreId   String?  @map("origin_store_id")
  originStore     Store?   @relation("CustomerOriginStore", fields: [originStoreId], references: [id])
  originSeller    String?  @map("origin_seller")
  // -- Loja física "candidata" pra cliente misto (WC perto de loja) --
  // Atribuído via range de CEP. Cliente continua originStoreId=SITE (13)
  // mas vendedora física vê ele com badge "🌐 SITE" na lista da sua loja.
  targetStoreId   String?  @map("target_store_id")
  targetStore     Store?   @relation("CustomerTargetStore", fields: [targetStoreId], references: [id])
  referredById    String?  @map("referred_by_id")
  referredBy      Customer? @relation("CustomerReferral", fields: [referredById], references: [id])
  referrals       Customer[] @relation("CustomerReferral")

  // -- Tier e segmentacao --
  vipTier         String   @default("bronze") @map("vip_tier")
  tierEnteredAt   DateTime? @map("tier_entered_at")
  rfvSegment      String?  @map("rfv_segment")
  rfvEngagement   Int      @default(0) @map("rfv_engagement")

  // -- Metricas calculadas (job diario) --
  livesAttended   Int      @default(0) @map("lives_attended")
  ltvCents        BigInt   @default(0) @map("ltv_cents")
  orderCount      Int      @default(0) @map("order_count")
  ticketMedioCents Int     @default(0) @map("ticket_medio_cents")
  firstOrderAt    DateTime? @map("first_order_at")
  lastOrderAt     DateTime? @map("last_order_at")

  // -- Status --
  active          Boolean  @default(true)
  inactiveReason  String?  @map("inactive_reason")

  // -- Observacoes livres --
  notes           String?

  // ─── DADOS GIGA (Wincred) ───────────────────────────────────────────────
  // Importados via ETL Giga clientes. Vendedora física precisa desses pra
  // crediário, KYC, atendimento personalizado.
  naturalidade        String?
  pai                 String?
  mae                 String?
  conjugeNome         String?  @map("conjuge_nome")
  conjugeCpf          String?  @map("conjuge_cpf")
  // Trabalho
  trabalhoRazaoSocial String?  @map("trabalho_razao_social")
  trabalhoCargo       String?  @map("trabalho_cargo")
  trabalhoSalarioCents BigInt? @map("trabalho_salario_cents")
  trabalhoAdmissao    DateTime? @map("trabalho_admissao") @db.Date
  trabalhoFone        String?  @map("trabalho_fone")
  // Contato de recado
  nomeRecado          String?  @map("nome_recado")
  foneRecado          String?  @map("fone_recado")
  // Status crediário Giga (snapshot do ETL)
  limiteCrediarioCents BigInt? @map("limite_crediario_cents")
  bloqueadoGiga       Boolean  @default(false) @map("bloqueado_giga")
  negativadoGiga      Boolean  @default(false) @map("negativado_giga")
  fidelidadeGiga      String?  @map("fidelidade_giga")
  spcSituacao         String?  @map("spc_situacao")
  spcData             DateTime? @map("spc_data") @db.Date
  // Datas históricas Giga
  gigaPrimeiraCompra  DateTime? @map("giga_primeira_compra") @db.Date
  gigaUltimaCompra    DateTime? @map("giga_ultima_compra") @db.Date
  // Moradia
  casaPropria         Boolean? @map("casa_propria")
  aluguelCents        BigInt?  @map("aluguel_cents")
  // Snapshot bruto da linha do Giga clientes (todas as ~75 colunas em JSON).
  // Pra mineração futura sem precisar mudar ETL. Atualizado a cada sync.
  gigaRawData         Json?    @map("giga_raw_data")

  // ─── APP CLIENTE FINAL ──────────────────────────────────────────────────────
  // ATENÇÃO: os campos de auth/PWA do app foram MOVIDOS pra `CustomerAccount`
  // a partir de jun/2026. Customer continua sendo "1 por loja Giga" (regra
  // ERP), mas a IDENTIDADE DO APP fica em CustomerAccount (1 por pessoa).
  // Cliente vinculado ao app: tem 1+ CustomerAccountLink → CustomerAccount.

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // -- Relations --
  comments              Comment[]
  reservations          Reservation[]
  liveCarts             LiveCart[]
  dmMessages            DmMessage[]
  addresses             CustomerAddress[]
  consents              CustomerConsent[]
  cashbackBalance       CashbackBalance?
  cashbackTransactions  CashbackTransaction[]
  tags                  CustomerTag[]
  rfvSnapshots          CustomerRfvSnapshot[]
  gigaLinks             CustomerGigaLink[]
  accountLinks          CustomerAccountLink[]

  @@index([cpf])
  @@index([personKey])
  @@index([phone])
  @@index([whatsapp])
  @@index([vipTier])
  @@index([rfvSegment])
  @@index([originStoreId])
  @@index([targetStoreId])
  @@index([lastOrderAt])
  @@index([liveRegisteredAt])
  // Dashboard CRM filtra por loja e ordena por recência — composto evita
  // combinar dois índices single-column (filtro + sort).
  @@index([originStoreId, lastOrderAt(sort: Desc)])
  // Verificador anti-duplicata da Live busca por @ do Instagram a cada cadastro.
  @@index([igUsername])
  @@map("customers")
}

// ===========================================================================
// CustomerAccount — IDENTIDADE DO APP CLIENTE FINAL (app.lurds.com.br PWA).
//
// 1 CustomerAccount por PESSOA REAL (chave: CPF).
// Vincula a N Customer (1 por loja Giga onde ela já comprou).
//
// Por que existir como entidade separada do Customer:
//   - Customer no schema atual = "cadastro por loja" (regra Giga ERP).
//     Cliente que comprou em 5 lojas tem 5 Customer com mesmo CPF.
//   - Mas DO PONTO DE VISTA DO APP, cliente é UMA pessoa só. Senha única,
//     cashback consolidado, push notification única, perfil unificado.
//   - Resolvermos isso aglutinando no Customer mais antigo seria frágil:
//     se ele cadastra em loja nova depois, a chave do app teria que migrar.
//
// CustomerAccount resolve isso: ele é "a conta do app". Customer continua
// sendo "o cadastro da loja". Linking via CustomerAccountLink.
//
// Login: CPF → CustomerAccount → JWT(sub=account.id, scope='customer').
// /me: consolida ltvCents, orderCount etc. somando de TODOS Customer linkados.
// Cashback: 1 saldo único por CustomerAccount (independe de em qual loja
// foi acumulado).
// ===========================================================================
model CustomerAccount {
  id                    String   @id @default(uuid())

  // Identidade — CPF é a chave única (1 conta por pessoa)
  cpf                   String   @unique
  // Pra mostrar na UI / push notification. Vem do Customer mais antigo,
  // mas cliente pode editar em /conta/dados.
  name                  String?
  phone                 String?
  email                 String?  @unique
  // Data de nascimento — opcional no cadastro. Usada pra campanha "mimo
  // de aniversário" (push promo + R$30 cashback extra no mês do aniversário).
  // Se cliente já tem Customer linked com birthDate, podemos copiar via job.
  birthDate             DateTime? @map("birth_date") @db.Date

  // ─── Auth do app ───
  passwordHash          String   @map("password_hash") // bcrypt obrigatório
  lastLoginAt           DateTime? @map("last_login_at")

  // ─── Estado do PWA ───
  pwaInstalledAt        DateTime? @map("pwa_installed_at")
  welcomeBonusAt        DateTime? @map("welcome_bonus_at")
  pushOptIn             Boolean  @default(false) @map("push_opt_in")
  // Fallback WhatsApp — pra clientes que não conseguem push (iOS antigo,
  // cliente que não quer instalar PWA, ou que prefere WhatsApp mesmo).
  // Quando admin dispara push e cliente tem essa flag, manda WhatsApp também.
  whatsappOptIn         Boolean  @default(false) @map("whatsapp_opt_in")

  // ─── Cashback unificado (em centavos) ───
  // Saldo único independente de em qual loja Giga foi gerado.
  // Quando cliente compra em qualquer loja, o cashback creditado vai aqui.
  cashbackBalanceCents  Int      @default(0) @map("cashback_balance_cents")
  cashbackEarnedCents   BigInt   @default(0) @map("cashback_earned_cents")
  cashbackSpentCents    BigInt   @default(0) @map("cashback_spent_cents")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  links                 CustomerAccountLink[]
  pushSubscriptions     CustomerAppPushSubscription[]
  cashbackTxs           CustomerCashbackTx[]
  passwordResetTokens   CustomerPasswordResetToken[]
  notifications         CustomerAppNotification[]

  @@index([cpf])
  @@map("customer_accounts")
}

// ===========================================================================
// CustomerAccountLink — vincula 1 CustomerAccount (app) a N Customer (lojas).
//
// Criado automaticamente:
//   - No register: vincula a todos Customer com mesmo CPF que existirem.
//   - No ETL Giga: quando importa Customer novo cujo CPF já tem account,
//     adiciona o link automaticamente.
//
// `isPrimary` = Customer escolhido como "fonte oficial" dos dados (nome,
// telefone, endereço default). Geralmente o mais antigo (primeira loja
// onde comprou).
// ===========================================================================
// ===========================================================================
// CustomerPasswordResetToken — código de 6 dígitos enviado por WhatsApp
// pra reset de senha do app.
//
// Validade: 15 min. Limite: 3 tentativas. Após uso, fica `usedAt` setado.
// ===========================================================================
model CustomerPasswordResetToken {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  account     CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  code        String                                    // 6 dígitos hash
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([accountId, createdAt])
  @@map("customer_password_reset_tokens")
}

// ===========================================================================
// AppInviteToken — captação de cliente no PDV via QR Code.
//
// Após vendedora finalizar venda, sistema gera QR único:
//   1. cliente lê QR → abre app.lurds.com.br/?invite=TOKEN
//   2. cliente se cadastra (token é guardado no app)
//   3. ao concluir cadastro, backend valida token, marca origin=PDV,
//      credita R$ 20 IMEDIATAMENTE (não espera 1ª compra — vendedora
//      precisa do incentivo na hora).
//
// Token expira em 7 dias se não for usado.
// Cada venda gera 1 token. Pra rastrear conversão por loja/vendedora.
// ===========================================================================
model AppInviteToken {
  id              String   @id @default(uuid())
  token           String   @unique     // ULID/UUID curto, pra QR ficar pequeno
  storeCode       String   @map("store_code")
  sellerName      String?  @map("seller_name")
  pdvSaleId       String?  @map("pdv_sale_id")
  customerCpf     String?  @map("customer_cpf")   // se vendedora já bipou CPF
  bonusCents      Int      @default(2000) @map("bonus_cents")
  usedByAccountId String?  @map("used_by_account_id")
  usedAt          DateTime? @map("used_at")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([storeCode])
  @@index([sellerName])
  @@index([usedByAccountId])
  @@map("app_invite_tokens")
}

// ===========================================================================
// CustomerCashbackTx — extrato de cashback do app cliente final.
//
// Independente do CashbackTransaction do CRM (que usa Customer.id).
// Aqui vinculamos ao CustomerAccount, então saldo é único por pessoa
// (mesmo que ela tenha N Customer em N lojas Giga).
//
// Tipos:
//   - earn:       crédito por compra (10% sobre valor)
//   - welcome:    bônus R$ 20 (instalação + 1ª compra)
//   - redeem:     usado pra abater na próxima compra (positivo = saída)
//   - expire:     expirado por TTL (30 dias)
//   - adjust:     ajuste manual admin (+ ou −)
//
// expiresAt: quando o crédito expira (ganhos expiram em 30 dias por default).
//            Job diário roda e marca expired conforme essa data.
// ===========================================================================
model CustomerCashbackTx {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  account         CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type            String   // 'earn' | 'welcome' | 'redeem' | 'expire' | 'adjust'
  amountCents     Int      @map("amount_cents")  // positivo = crédito, negativo = uso
  balanceAfterCents Int    @map("balance_after_cents") // snapshot saldo após esta tx
  description     String?
  orderId         String?  @map("order_id")        // se gerado por Order do site
  pdvSaleId       String?  @map("pdv_sale_id")     // se gerado por PDV
  expiresAt       DateTime? @map("expires_at")     // só pra 'earn'/'welcome'
  expiredAt       DateTime? @map("expired_at")     // setado quando vira 'expire'
  notifiedExpireWarning Boolean @default(false) @map("notified_expire_warning") // alerta D-7 já enviado
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([accountId, createdAt])
  @@index([accountId, type])
  @@index([expiresAt, expiredAt])
  @@map("customer_cashback_txs")
}

// ===========================================================================
// CustomerAppPushSubscription — VAPID push subscriptions do app cliente final.
//
// Separado de PushSubscription (operador/User) pra:
//   - Targetar push só pra clientes (não operadores)
//   - Permitir múltiplos devices por account (celular + tablet)
//   - Trackear engajamento (lastUsed)
// ===========================================================================
model CustomerAppPushSubscription {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  account     CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  endpoint    String   @unique // chave única — identifica device
  p256dh      String              // chave pública ECDH (criptografia)
  auth        String              // segredo de autenticação
  userAgent   String?  @map("user_agent")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  lastUsed    DateTime @default(now()) @map("last_used")

  @@index([accountId])
  @@index([active])
  @@map("customer_app_push_subscriptions")
}

// Histórico de notificações enviadas — alimenta a tela /notificacoes do app PWA.
// Gravamos toda vez que CustomerPushService dispara, independente de chegar no device
// (cliente pode ter desativado push, instalado em outro device, ainda assim quer ver histórico).
model CustomerAppNotification {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  account      CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title        String
  body         String?
  url          String?              // link interno do app
  image        String?              // banner rico
  tag          String?              // agrupa notifs do mesmo tipo
  category     String?              // 'promo' | 'order' | 'cashback' | 'live' | 'system'
  readAt       DateTime? @map("read_at")
  pushSent     Boolean   @default(false) @map("push_sent")
  whatsappSent Boolean   @default(false) @map("whatsapp_sent")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([accountId, createdAt])
  @@index([accountId, readAt])
  @@map("customer_app_notifications")
}

model CustomerAccountLink {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  customerId  String   @map("customer_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  linkedAt    DateTime @default(now()) @map("linked_at")

  account     CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([accountId, customerId])
  @@index([accountId])
  @@index([customerId])
  @@map("customer_account_links")
}

// ===========================================================================
// CustomerGigaLink — chave composta (loja, codigo) do Giga Wincred.
//
// Resolve bug crítico descoberto em jun/2026: o Giga usa contador de
// cadastros POR LOJA, então codigo=1 existe em CADA uma das 14 lojas. O
// campo `Customer.registroGiga` (Int único) era ambíguo — várias linhas
// Giga colidiam na mesma chave.
//
// Agora cada cadastro Giga vira UM link. Múltiplos links podem apontar
// pro mesmo Customer (deduplicado por CPF). Cliente sem CPF: cada link
// vira Customer separado.
//
// `originStoreId` do Customer = loja do link mais antigo (cadastrou
// primeiro).
// ===========================================================================
model CustomerGigaLink {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  gigaLoja    String   @map("giga_loja")    // "01", "02", "04"...
  gigaCodigo  Int      @map("giga_codigo")  // 1, 2, 1234...
  ultimoSync  DateTime @default(now()) @map("ultimo_sync")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([gigaLoja, gigaCodigo], name: "giga_loja_codigo_unique")
  @@index([customerId])
  @@map("customer_giga_links")
}

// ===========================================================================
// CustomerAddress - enderecos (N por cliente).
// Tipos: residential / delivery / mailing / work.
// ===========================================================================
model CustomerAddress {
  id              String   @id @default(uuid())
  customerId      String   @map("customer_id")
  type            String
  isPrimary       Boolean  @default(false) @map("is_primary")

  cep             String?
  street          String?
  number          String?
  complement      String?
  district        String?
  city            String?
  state           String?
  reference       String?

  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([cep])
  @@map("customer_addresses")
}

// ===========================================================================
// CustomerConsent - historico de opt-ins/opt-outs LGPD.
// Linha NUNCA e apagada. Cada evento vira nova linha.
// ===========================================================================
model CustomerConsent {
  id                  String   @id @default(uuid())
  customerId          String   @map("customer_id")
  channel             String
  granted             Boolean
  grantedAt           DateTime @default(now()) @map("granted_at")
  termVersion         String?  @map("term_version")
  source              String?
  ipAddress           String?  @map("ip_address")
  registeredByUserId  String?  @map("registered_by_user_id")

  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, channel, grantedAt])
  @@map("customer_consents")
}

// ===========================================================================
// CashbackBalance - saldo atual (1:1 com Customer).
// Atualizado automaticamente via service apos cada CashbackTransaction.
// Valores em centavos (Int).
// ===========================================================================
model CashbackBalance {
  customerId             String    @id @map("customer_id")
  balanceCents           Int       @default(0) @map("balance_cents")
  accumulatedTotalCents  BigInt    @default(0) @map("accumulated_total_cents")
  redeemedTotalCents     BigInt    @default(0) @map("redeemed_total_cents")
  expiredTotalCents      BigInt    @default(0) @map("expired_total_cents")
  nextExpirationAt       DateTime? @map("next_expiration_at") @db.Date
  nextExpirationCents    Int       @default(0) @map("next_expiration_cents")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  customer               Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("cashback_balances")
}

// ===========================================================================
// CashbackTransaction - extrato completo de cashback (auditoria).
// Tipos: credit | redeem | expiration | reversal | manual_adjustment
// ===========================================================================
model CashbackTransaction {
  id                  String    @id @default(uuid())
  customerId          String    @map("customer_id")
  type                String
  valueCents          Int       @map("value_cents")
  balanceBeforeCents  Int?      @map("balance_before_cents")
  balanceAfterCents   Int?      @map("balance_after_cents")

  orderId             String?   @map("order_id")
  storeId             String?   @map("store_id")
  purchaseValueCents  Int?      @map("purchase_value_cents")
  percentApplied      Decimal?  @db.Decimal(5, 2) @map("percent_applied")

  creditedAt          DateTime? @map("credited_at") @db.Date
  expiresAt           DateTime? @map("expires_at") @db.Date

  description         String?
  userId              String?   @map("user_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  customer            Customer  @relation(fields: [customerId], references: [id])
  store               Store?    @relation("StoreCashbackTransactions", fields: [storeId], references: [id])

  @@index([customerId, createdAt])
  @@index([expiresAt])
  @@index([type])
  @@map("cashback_transactions")
}

// ===========================================================================
// Tag - catalogo de tags reutilizaveis.
// ===========================================================================
model Tag {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  color        String   @default("#888888")
  createdAt    DateTime @default(now()) @map("created_at")

  customers    CustomerTag[]

  @@map("tags")
}

// ===========================================================================
// CustomerTag - relacionamento N:N entre Customer e Tag.
// ===========================================================================
model CustomerTag {
  customerId  String   @map("customer_id")
  tagId       String   @map("tag_id")
  appliedAt   DateTime @default(now()) @map("applied_at")
  appliedBy   String?  @map("applied_by")

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@index([tagId])
  @@map("customer_tags")
}

// ===========================================================================
// CustomerRfvSnapshot - snapshot mensal pra ver evolucao RFV no tempo.
// ===========================================================================
model CustomerRfvSnapshot {
  id              String   @id @default(uuid())
  customerId      String   @map("customer_id")
  snapshotDate    DateTime @map("snapshot_date") @db.Date
  recencyDays     Int      @map("recency_days")
  frequency12m    Int      @map("frequency_12m")
  value12mCents   BigInt   @map("value_12m_cents")
  segment         String
  tier            String
  createdAt       DateTime @default(now()) @map("created_at")

  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, snapshotDate])
  @@index([customerId, snapshotDate])
  @@map("customer_rfv_snapshots")
}

model Live {
  id           String   @id @default(uuid())
  igMediaId    String?  @unique @map("ig_media_id")
  title        String
  status       String   @default("scheduled") // scheduled | live | ended | archived
  hostUserId   String?  @map("host_user_id")
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  aiEnabled    Boolean  @default(true) @map("ai_enabled")
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  products     LiveProduct[]
  comments     Comment[]
  reservations Reservation[]
  carts        LiveCart[]

  @@map("lives")
}

model LiveProduct {
  id              String   @id @default(uuid())
  liveId          String   @map("live_id")
  erpProductId    String   @map("erp_product_id")
  refCode         String   @map("ref_code")
  displayName     String   @map("display_name")
  priceCents      Int      @map("price_cents")
  promoPriceCents Int?     @map("promo_price_cents")
  sizes           Json     // [{ "size": "54", "stock": 8 }]
  position        Int
  shownAt         DateTime? @map("shown_at")
  endedShownAt    DateTime? @map("ended_shown_at")
  isCurrent       Boolean  @default(false) @map("is_current")
  commentsCount   Int      @default(0) @map("comments_count")
  reservationsCnt Int      @default(0) @map("reservations_cnt")
  salesCount      Int      @default(0) @map("sales_count")
  wcProductId     String?  @map("wc_product_id")
  createdAt       DateTime @default(now()) @map("created_at")

  live            Live          @relation(fields: [liveId], references: [id], onDelete: Cascade)
  comments        Comment[]
  reservations    Reservation[]

  @@unique([liveId, refCode])
  @@map("live_products")
}

model Comment {
  id              String   @id @default(uuid())
  liveId          String   @map("live_id")
  igCommentId     String   @unique @map("ig_comment_id")
  igUserId        String   @map("ig_user_id")
  igUsername      String   @map("ig_username")
  rawText         String   @map("raw_text")
  normalizedText  String?  @map("normalized_text")
  detectedIntent  String?  @map("detected_intent")
  detectedCode    String?  @map("detected_code")
  detectedSize    String?  @map("detected_size")
  confidence      Decimal? @db.Decimal(3, 2)
  liveProductId   String?  @map("live_product_id")
  customerId      String?  @map("customer_id")
  aiAnswer        String?  @map("ai_answer")
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  live            Live         @relation(fields: [liveId], references: [id], onDelete: Cascade)
  liveProduct     LiveProduct? @relation(fields: [liveProductId], references: [id], onDelete: SetNull)
  customer        Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // FKs sem índice faziam a listagem de comentários da live e o onDelete:Cascade
  // varrerem a tabela inteira.
  @@index([liveId, createdAt(sort: Desc)])
  @@index([customerId])
  @@index([liveProductId])
  @@map("comments")
}

model Reservation {
  id              String   @id @default(uuid())
  liveId          String   @map("live_id")
  liveProductId   String   @map("live_product_id")
  customerId      String   @map("customer_id")
  commentId       String?  @map("comment_id")
  size            String
  qty             Int      @default(1)
  priceCents      Int      @map("price_cents")
  status          String   @default("reserved") // reserved | confirmed | paid | expired | cancelled
  source          String   @default("comment")  // comment | dm | site | manual
  reservedAt      DateTime @default(now()) @map("reserved_at")
  expiresAt       DateTime @map("expires_at")
  confirmedAt     DateTime? @map("confirmed_at")
  paidAt          DateTime? @map("paid_at")
  cancelledAt     DateTime? @map("cancelled_at")
  erpOrderId      String?  @map("erp_order_id")
  wcOrderId       String?  @map("wc_order_id")
  notes           String?

  live            Live         @relation(fields: [liveId], references: [id])
  liveProduct     LiveProduct  @relation(fields: [liveProductId], references: [id])
  customer        Customer     @relation(fields: [customerId], references: [id])

  // Cron de expiração roda a cada 30s filtrando (status, expiresAt); os demais
  // cobrem os lookups por produto/cliente e as FKs. Tabela não tinha índice.
  @@index([status, expiresAt])
  @@index([liveProductId, customerId, size, status])
  @@index([liveId])
  @@index([customerId])
  @@map("reservations")
}

model LiveCart {
  id            String   @id @default(uuid())
  liveId        String   @map("live_id")
  customerId    String   @map("customer_id")
  status        String   @default("open") // open | checked_out | abandoned
  totalCents    Int      @default(0) @map("total_cents")
  checkoutUrl   String?  @map("checkout_url")
  wcOrderId     String?  @map("wc_order_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  live          Live     @relation(fields: [liveId], references: [id], onDelete: Cascade)
  customer      Customer @relation(fields: [customerId], references: [id])

  @@unique([liveId, customerId])
  @@map("live_carts")
}

model DmMessage {
  id            String   @id @default(uuid())
  customerId    String   @map("customer_id")
  liveId        String?  @map("live_id")
  direction     String                          // in | out
  channel       String                          // ig_direct | whatsapp
  igMessageId   String?  @map("ig_message_id")
  body          String
  template      String?
  aiGenerated   Boolean  @default(false) @map("ai_generated")
  status        String   @default("queued")     // queued | sent | delivered | read | failed
  error         String?
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime @default(now()) @map("created_at")

  customer      Customer @relation(fields: [customerId], references: [id])

  // Inbox da live faz JOIN LATERAL por customer_id ordenando por created_at DESC
  // (última msg) + COUNT de não-lidas. Sem índice, degradava quadraticamente.
  @@index([customerId, createdAt(sort: Desc)])
  @@map("dm_messages")
}

// ════════════════════════════════════════════════════════════════════════
// IMOBILIÁRIO — gestão de imóveis (água, energia, IPTU, taxas, matrícula,
// escritura, anexos). Roles separadas: imobiliario_admin, imobiliario_user,
// imobiliario_viewer. `admin` (geral) também acessa. Storage Vercel Blob.
// Audit log granular (PropertyLog) registra cada mudança com user + diff.
// ════════════════════════════════════════════════════════════════════════

model Property {
  id              String   @id @default(uuid())
  // Identificação
  name            String                          // "Apto Moema 302", "Sala Vila Olímpia", etc
  // Endereço (ViaCEP auto-preenche)
  cep             String?
  endereco        String?                         // logradouro
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?                         // UF
  // Status (controlado por code, label em PT no front)
  status          String   @default("ativo")      // ativo | em_construcao | pronta_locacao | inativo | vendido
  // Proprietário (free text — em V2 vira FK)
  proprietario    String?
  observacoes     String?  @db.Text
  // Audit + soft delete
  archivedAt      DateTime? @map("archived_at")
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 1:1 — cada imóvel tem no máximo 1 conta de cada utility
  water           PropertyWaterAccount?
  energy          PropertyEnergyAccount?
  iptu            PropertyIptu?
  deed            PropertyDeed?
  scripture       PropertyScripture?
  // 1:N — múltiplas taxas, anexos e logs
  taxes           PropertyTax[]
  attachments     PropertyAttachment[]
  logs            PropertyLog[]

  @@index([status])
  @@index([cidade])
  @@index([archivedAt])
  @@map("properties")
}

model PropertyWaterAccount {
  id                  String   @id @default(uuid())
  propertyId          String   @unique @map("property_id")
  property            Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  companhia           String?
  titular             String?
  codigoFornecimento  String?  @map("codigo_fornecimento")
  vencimentoDia       Int?     @map("vencimento_dia")     // dia do mês 1-31
  observacoes         String?  @db.Text
  attachmentUrl       String?  @map("attachment_url")     // PDF/JPG mais recente
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("property_water_accounts")
}

model PropertyEnergyAccount {
  id              String   @id @default(uuid())
  propertyId      String   @unique @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  companhia       String?
  titular         String?
  codigoCliente   String?  @map("codigo_cliente")
  vencimentoDia   Int?     @map("vencimento_dia")
  observacoes     String?  @db.Text
  attachmentUrl   String?  @map("attachment_url")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("property_energy_accounts")
}

model PropertyIptu {
  id              String   @id @default(uuid())
  propertyId      String   @unique @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  proprietario    String?
  codigoCadastro  String?  @map("codigo_cadastro")
  valorAnual      Float?   @map("valor_anual")
  situacao        String?                                  // em_dia | em_atraso | parcelado
  dataVencimento  DateTime? @map("data_vencimento")
  observacoes     String?  @db.Text
  attachmentUrl   String?  @map("attachment_url")          // carnê IPTU
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("property_iptus")
}

model PropertyTax {
  // taxas múltiplas: condomínio, lixo, foro, associação, etc
  id              String   @id @default(uuid())
  propertyId      String   @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tipo            String                                   // condominio | lixo | foro | associacao | outros
  nome            String?                                  // descrição livre se tipo='outros'
  codigo          String?
  valor           Float?
  vencimentoDia   Int?     @map("vencimento_dia")
  observacoes     String?  @db.Text
  attachmentUrl   String?  @map("attachment_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([propertyId])
  @@map("property_taxes")
}

model PropertyDeed {
  // matrícula
  id              String   @id @default(uuid())
  propertyId      String   @unique @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  numero          String?
  cartorio        String?
  cidadeCartorio  String?  @map("cidade_cartorio")
  dataEmissao     DateTime? @map("data_emissao")
  observacoes     String?  @db.Text
  attachmentUrl   String?  @map("attachment_url")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("property_deeds")
}

model PropertyScripture {
  // escritura
  id              String   @id @default(uuid())
  propertyId      String   @unique @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  numero          String?
  data            DateTime?
  livro           String?
  folha           String?
  cartorio        String?
  observacoes     String?  @db.Text
  attachmentUrl   String?  @map("attachment_url")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("property_scriptures")
}

model PropertyAttachment {
  // anexos GERAIS (fora das categorias 1:1 acima). Categoria fixa ou custom.
  id              String   @id @default(uuid())
  propertyId      String   @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category        String                                   // Foto | Contrato | Comprovante | Documento Cartório | Outros | <custom>
  fileName        String   @map("file_name")
  fileUrl         String   @map("file_url")               // Vercel Blob URL
  fileSize        Int?     @map("file_size")              // bytes
  mimeType        String?  @map("mime_type")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  uploadedByUserId String? @map("uploaded_by_user_id")
  uploadedByName  String?  @map("uploaded_by_name")

  @@index([propertyId, category])
  @@map("property_attachments")
}

// ════════════════════════════════════════════════════════════════════════
// PURCHASE ORDERS — pedidos de compra do fornecedor.
// Fluxo: Cria pedido (header + items REF×COR×TAMs com QTYs) → Status pending →
// Mercadoria chega → Confere/ajusta → Marca recebido → Sistema AUTO-CADASTRA
// SKUs no Wincred (gera EAN-13 prefixo 8) + atualiza estoque + fila de etiquetas.
// ════════════════════════════════════════════════════════════════════════

model PurchaseOrder {
  id              String   @id @default(uuid())
  numero          Int      @unique @default(autoincrement())          // sequencial #1, #2...
  fornecedorNome  String   @map("fornecedor_nome")                   // ex: "MARRIE ARIMATH"
  fornecedorCnpj  String?  @map("fornecedor_cnpj")
  marca           String?                                              // fantasia do fornecedor (= MARCA na descrição)
  dataPedido      DateTime @default(now()) @map("data_pedido")
  dataPrevista    DateTime? @map("data_prevista")                     // SLA de chegada
  nfNumero        String?  @map("nf_numero")
  observacoes     String?  @db.Text
  // Status: rascunho | enviado | aguardando | recebido | cancelado
  status          String   @default("rascunho")
  // Calculados (atualizados quando salva items)
  totalPecas      Int      @default(0) @map("total_pecas")
  totalCusto      Float    @default(0) @map("total_custo")            // sem desconto/imposto
  totalLiquido    Float    @default(0) @map("total_liquido")
  totalVenda      Float    @default(0) @map("total_venda")            // soma preço venda × qty
  // Audit
  createdByUserId String?  @map("created_by_user_id")
  recebidoAt      DateTime? @map("recebido_at")
  recebidoByUserId String? @map("recebido_by_user_id")
  cadastroLog     String?  @map("cadastro_log") @db.Text               // JSON com resumo do auto-cadastro
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items           PurchaseOrderItem[]

  @@index([status])
  @@index([fornecedorNome])
  @@index([dataPedido(sort: Desc)])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  // 1 linha = 1 REF + 1 COR + grade de tamanhos com qtd em cada.
  // Ex: REF 7031, COR PRETO, tamanhosQty = {"46": 21, "48": 21, "56": 18}
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Identificação do produto
  ref             String                                               // REF do fornecedor
  descricaoBase   String   @map("descricao_base")                     // "CASACO SOFT" (do pedido)
  cor             String
  // Categoria (vem do CategoriaProduto OU preenchido manualmente)
  grupoCode       Int?     @map("grupo_code")
  grupoNome       String?  @map("grupo_nome")                         // "BLUSA FEMININA"
  subgrupoCode    Int?     @map("subgrupo_code")
  subgrupoNome    String?  @map("subgrupo_nome")                      // "ACADEMIA"
  ncm             String?
  cfop            String?  @default("5102")
  plusSize        Boolean  @default(true) @map("plus_size")
  // Valores comerciais
  custoUnit       Float    @map("custo_unit")
  precoUnit       Float    @map("preco_unit")
  tributoPct      Float    @default(0) @map("tributo_pct")            // % de imposto (independente do NCM)
  descontoPct     Float    @default(0) @map("desconto_pct")
  // Grades — armazena qty por tamanho como JSON pra flexibilidade
  // formato: {"46": 21, "48": 21, "50": 21, ...}
  tamanhosQty     String   @map("tamanhos_qty") @db.Text              // JSON
  // Quando recebido, guarda qty REAL (pode ser menor que pedido)
  tamanhosQtyRecebida String? @map("tamanhos_qty_recebida") @db.Text  // JSON
  // SKUs gerados no Wincred após auto-cadastro (rastreabilidade)
  // formato: [{tam, codigoWincred, ean, qtdInserida}, ...]
  skusGerados     String?  @map("skus_gerados") @db.Text              // JSON
  // Status do ITEM (não confundir com status do pedido)
  // pendente | recebido | parcial | cancelado
  itemStatus      String   @default("pendente") @map("item_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([ref])
  @@map("purchase_order_items")
}

model CategoriaProduto {
  // Mapeamento "descrição da planilha" → Grupo+Subgrupo+NCM+CFOP.
  // Cadastrado 1x quando vem REF nova, reusa pra sempre.
  // Ex: descricaoBase="CASACO SOFT" → BLUSA FEMININA / ACADEMIA / NCM 61102000
  // NOTA: tributo NÃO está aqui — é por item (pode variar por fornecedor).
  id              String   @id @default(uuid())
  descricaoBase   String   @unique @map("descricao_base")             // PK lógica
  grupoCode       Int      @map("grupo_code")
  grupoNome       String   @map("grupo_nome")
  subgrupoCode   Int      @map("subgrupo_code")
  subgrupoNome   String   @map("subgrupo_nome")
  ncmDefault      String?  @map("ncm_default")
  cfopDefault     String?  @default("5102") @map("cfop_default")
  plusSizeDefault Boolean  @default(true) @map("plus_size_default")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("categoria_produtos")
}

model PropertyLog {
  // audit trail granular: 1 linha por mudança (campo, before/after, user, ts).
  // Usado pra timeline do imóvel + investigar quem mexeu no quê.
  id              String   @id @default(uuid())
  propertyId      String   @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId          String?  @map("user_id")
  userName        String?  @map("user_name")
  action          String                                   // create | update | archive | unarchive | upload | delete_attachment
  scope           String?                                  // property | water | energy | iptu | tax | deed | scripture | attachment
  details         String?  @db.Text                        // JSON: { field, oldValue, newValue } ou descrição livre
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([propertyId, createdAt(sort: Desc)])
  @@map("property_logs")
}

// ════════════════════════════════════════════════════════════════════════
// ProductPhoto — fotos de produtos (por REF, opcionalmente por COR)
// Usado em Reposicao, PDV, Separacao, Realinhamento.
// Upload via R2 (mesma infra do Imobiliario).
// ════════════════════════════════════════════════════════════════════════
model ProductPhoto {
  id              String   @id @default(uuid())
  ref             String                              // REF do produto (Wincred)
  cor             String?                             // null = foto generica da REF
  url             String   @db.Text                   // URL publica no R2
  objectKey       String?  @map("object_key") @db.Text // chave no bucket pra delete
  uploadedByUserId String? @map("uploaded_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([ref, cor], name: "ref_cor_unique")
  @@index([ref])
  @@map("product_photos")
}

// ═══════════════════════════════════════════════════════════════════════
// ESTOQUE — espelho do Wincred no PostgreSQL pra migração 30/06
// ═══════════════════════════════════════════════════════════════════════
// Fase 2 da migração Giga → Flowops. Sync via /retaguarda/estoque/sync
// pega da tabela `estoque` do Wincred (SELECT CODIGO, LOJA, ESTOQUE).
// Foco inicial nas 5 lojas migradas (INDAIATUBA, ITANHAEM, MOEMA, SOROCABA, SANTOS).
//
// Quando PDV finalizar venda, decrementa AQUI primeiro (read fast) + grava
// também no Giga via double-write. Quando Giga sair, é só remover a chamada.
model Stock {
  id        String   @id @default(uuid())
  storeCode String   @map("store_code")
  sku       String                          // CODIGO do Wincred
  qty       Int      @default(0)            // estoque disponível
  syncedAt  DateTime @default(now()) @map("synced_at")  // último sync do Giga
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([storeCode, sku])
  @@index([storeCode, qty])
  @@index([sku])
  @@map("stock")
}

// Log de toda movimentação de estoque — auditoria + reconciliação.
// reason: 'sync_giga' | 'sale' | 'return' | 'adjust' | 'transfer' | 'initial'
model StockMovement {
  id        String   @id @default(uuid())
  storeCode String   @map("store_code")
  sku       String
  delta     Int                              // negativo = saída, positivo = entrada
  qtyBefore Int      @map("qty_before")
  qtyAfter  Int      @map("qty_after")
  reason    String                           // categoria do movimento
  refId     String?  @map("ref_id")          // saleId / orderId / transferId
  note      String?                          // observação livre
  userId    String?  @map("user_id")         // quem fez (se aplicável)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeCode, sku, createdAt(sort: Desc)])
  @@index([reason, createdAt(sort: Desc)])
  @@index([refId])
  @@map("stock_movements")
}

// ════════════════════════════════════════════════════════════════════════
//  ERP OUTBOX — fila de escrita assíncrona no Giga/Wincred.
//
//  A venda finaliza SÓ no Postgres (instantâneo) e um job entra aqui.
//  Um processor (cron 30s) grava no Wincred (caixa + baixa de estoque) com
//  retry/backoff. Se o Giga estiver fora, a venda sai normal e o Wincred é
//  atualizado quando voltar. Sub-passos idempotentes: caixaDoneAt e
//  stockDoneAt marcam o que JÁ executou — retry nunca duplica INSERT na caixa.
// ════════════════════════════════════════════════════════════════════════
model ErpOutbox {
  id          String    @id @default(uuid())
  kind        String                          // 'venda' (finalize → caixa + estoque)
  saleId      String    @map("sale_id")
  payload     Json?                           // { finalMethod } — resto é re-lido do Postgres na hora
  status      String    @default("pending")   // pending | processing | done | failed
  attempts    Int       @default(0)
  caixaDoneAt DateTime? @map("caixa_done_at") // gravarVendaPdv OK (ou shadow)
  stockDoneAt DateTime? @map("stock_done_at") // decreaseStock OK (ou write desligado)
  lastError   String?   @map("last_error")
  nextRetryAt DateTime  @default(now()) @map("next_retry_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  doneAt      DateTime? @map("done_at")

  @@unique([kind, saleId])
  @@index([status, nextRetryAt])
  @@map("erp_outbox")
}

// ════════════════════════════════════════════════════════════════════════
//  WINCRED MIRROR — espelho 1:1 das 6 tabelas critícas do MySQL Wincred.
//
//  Estrategia: sync incremental por DATAALT (quando existir) + upsert.
//  Prefixo `wincred_*` deixa explicito que e espelho legacy. Quando
//  cut-over 30/06 acontecer, decidimos se mantemos prefixo ou renomeamos.
//
//  IMPORTANTE: estes models NAO sao a fonte da verdade para operações
//  novas (cadastro de produto, etc). Eles existem APENAS pra espelhar o
//  Wincred. Cadastro proprio = futura tabela `Product` sem prefixo.
// ════════════════════════════════════════════════════════════════════════

/// Espelho de wincred.produtos. Catalogo de SKUs.
/// PK = codigo (no Wincred nao tinha PK, vamos cravar — duplicatas viram update).
model WincredProduto {
  codigo            String    @id @db.VarChar(14)
  grupo             Int?
  nomeGrupo         String?   @db.VarChar(30)
  descricaoPdv      String?   @db.VarChar(50)
  descricaoCompleta String?   @db.VarChar(100)
  custo             Decimal?  @db.Decimal(10, 2)
  vendaUn           Decimal?  @db.Decimal(10, 2)
  fornecedor        String?   @db.VarChar(18)
  unidade           String?   @db.VarChar(2)
  estoque           Int?
  margem            Decimal?  @db.Decimal(10, 2)
  dataAlt           DateTime? @db.Date
  subgrupo          Int?
  cor               String?   @db.VarChar(15)
  tamanho           String?   @db.VarChar(20)
  marca             String?   @db.VarChar(30)
  ref               String?   @db.VarChar(10)
  codFornecedor     Int?
  operador          String?   @db.VarChar(15)
  confPreco         String?   @db.VarChar(3)
  tributo           String?   @db.VarChar(4)
  ncm               String?   @db.VarChar(8)
  plusSize          Int?
  idWincred         BigInt?
  categorias        String?   @db.VarChar(250)
  codPis            String?   @db.Char(2)
  aliqPis           Decimal?  @db.Decimal(10, 2)
  codCofins         String?   @db.Char(2)
  aliqCofins        Decimal?  @db.Decimal(10, 2)
  aliqIcms          Decimal?  @db.Decimal(10, 2)
  cst               String?   @db.Char(3)
  csosn             String?   @db.Char(3)
  cfop              Int?

  // Metadata de sync
  syncedAt          DateTime  @default(now()) @map("synced_at")

  @@index([ref, cor])
  @@index([dataAlt])
  @@index([grupo, subgrupo])
  @@index([plusSize, ref])
  @@index([descricaoCompleta])
  @@map("wincred_produtos")
}

/// Espelho de wincred.estoque. Qty por (codigo, loja).
/// PK composta replica o UNIQUE KEY uk_codigo_loja do Wincred.
model WincredEstoque {
  codigo   String  @db.VarChar(14)
  loja     String  @db.Char(2)
  estoque  Int?

  syncedAt DateTime @default(now()) @map("synced_at")

  @@id([codigo, loja])
  @@index([loja])
  @@map("wincred_estoque")
}

/// Espelho de wincred.grupos. Categorias.
model WincredGrupo {
  codigo Int    @id
  grupo  String? @db.VarChar(30)

  syncedAt DateTime @default(now()) @map("synced_at")

  @@map("wincred_grupos")
}

/// Espelho de wincred.subgrupos. Sub-categorias.
model WincredSubgrupo {
  codigo   Int     @id
  subgrupo String? @db.VarChar(30)
  grupo    Int?

  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([grupo])
  @@map("wincred_subgrupos")
}

/// Espelho de wincred.fornecedores.
model WincredFornecedor {
  codigo        Int       @id
  razaoSocial   String?   @db.VarChar(50)
  fantasia      String?   @db.VarChar(50)
  cnpj          String?   @db.VarChar(18)
  ie            String?   @db.VarChar(18)
  dataCadastro  DateTime? @db.Date
  endereco      String?   @db.VarChar(50)
  bairro        String?   @db.VarChar(30)
  cidade        String?   @db.VarChar(30)
  uf            String?   @db.Char(2)
  ddd           String?   @db.Char(5)
  fone          String?   @db.VarChar(16)
  fax           String?   @db.VarChar(16)
  cep           String?   @db.Char(10)
  email         String?   @db.VarChar(50)
  contato       String?   @db.VarChar(50)
  obs           Bytes?

  syncedAt      DateTime  @default(now()) @map("synced_at")

  @@index([cnpj])
  @@map("wincred_fornecedores")
}

/// Espelho de wincred.codigos. Tabela de sequencia (1 linha apenas).
/// Wincred guarda proximo CODIGO disponivel pra cadastro.
/// PK = codigo (a propria coluna serve como identificador).
model WincredCodigo {
  codigo String @id @db.VarChar(13)

  syncedAt DateTime @default(now()) @map("synced_at")

  @@map("wincred_codigos")
}

/// Espelho ENXUTO de wincred.movimento — SÓ parcelas de crediário EM ABERTO.
/// Full replace de hora em hora + write-through nas baixas do Flow. A tela
/// de cobrança (listAllOpenInstallments) lê daqui — a query que varria a
/// tabela movimento inteira no Giga (5.000 linhas / teto 30s) vira local.
model WincredMovimentoAberto {
  registro      String    @id
  controle      String?
  numeroCompra  String?   @map("numero_compra")
  loja          String?   @db.VarChar(4)
  codCliente    String?   @map("cod_cliente")
  nome          String?
  parcela       Int?
  totalParcelas Int?      @map("total_parcelas")
  vencimento    DateTime? @db.Date
  valorParcela  Decimal?  @map("valor_parcela") @db.Decimal(10, 2)

  syncedAt      DateTime  @default(now()) @map("synced_at")

  @@index([vencimento])
  @@index([codCliente])
  @@index([loja])
  @@map("wincred_movimento_aberto")
}

/// Espelho SLIM de clientes do Giga — nome + telefones pra cobrança/
/// recebimentos funcionarem com o Giga fora do ar.
/// ⚠️ CHAVE COMPOSTA (loja, codCliente): o CODIGO de cliente do Wincred se
/// REPETE entre lojas — cada loja tem sua numeração e seu crediário separado.
/// Antes (codCliente @id global) o sync sobrescrevia o cliente de uma loja
/// com o de outra. loja = char(2) do Giga; '00' = linha legada pré-migração
/// (o cron das 4h / primeira carga regrava tudo com a loja certa).
model WincredCliente {
  loja       String   @default("00") @db.VarChar(2)
  codCliente String   @map("cod_cliente")
  nome       String?
  telefone   String?
  telefone2  String?

  syncedAt   DateTime @default(now()) @map("synced_at")

  @@id([loja, codCliente])
  @@index([codCliente])
  @@map("wincred_clientes")
}

/// Estado do sync incremental. 1 linha por tabela.
/// Cron incremental usa lastDataAlt pra pegar so produtos modificados desde
/// o ultimo run (WHERE DATAALT > lastDataAlt). Estoque nao tem DATAALT — re-syncamos
/// estoque apenas dos produtos modificados (delta menor).
model WincredSyncState {
  tabela        String   @id @db.VarChar(30)
  lastRunAt     DateTime @default(now()) @map("last_run_at")
  lastDataAlt   DateTime? @map("last_data_alt") @db.Date
  lastRowCount  Int?     @map("last_row_count")
  lastStatus    String?  @db.VarChar(20)
  lastError     String?  @db.Text

  @@map("wincred_sync_state")
}

// ═══════════════════════════════════════════════════════════════════════════
// LIVE COMMERCE (operador) — módulo "Live PDV"
//
// Diferente do módulo Live/Instagram (orientado a comentários + estoque
// virtual). Aqui a APRESENTADORA opera ao vivo: busca REF, clica no tam/cor,
// identifica a cliente e reserva contra o ESTOQUE REAL CONSOLIDADO da rede.
//
// Fluxo:
//   1. Sessão da live aberta (loja da live = Anália Franco por padrão).
//   2. Operadora busca produto e clica numa célula da grade → cria LivePdvItem
//      (reserva com TTL). A loja de ORIGEM é escolhida automaticamente pelo
//      RoutingEngine (maior estoque → folga → prioridade → proximidade).
//   3. Reserva expira sozinha (cron) se não pagar dentro do TTL.
//   4. Pagamento PIX (Pagar.me/PagBank) confirma → itens viram 'paid' e
//      geram ordem de separação pra cada loja de origem.
//   5. Loja origem separa/despacha → cria TransferOrder (tipo LIVE) origem→
//      loja-da-live + InterStoreObligation (÷2,5) pra conciliação contábil.
// ═══════════════════════════════════════════════════════════════════════════
model LivePdvSession {
  id                String   @id @default(uuid())
  title             String
  status            String   @default("live")          // scheduled | live | ended
  liveStoreCode     String   @map("live_store_code")    // loja "dona" da venda (Anália Franco)
  liveStoreName     String   @map("live_store_name")
  reservationTtlMin Int      @default(30) @map("reservation_ttl_min")
  startedAt         DateTime? @map("started_at")
  endedAt           DateTime? @map("ended_at")
  createdByUserId   String?  @map("created_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  carts             LivePdvCart[]
  items             LivePdvItem[]
  atalhos           LivePdvAtalho[]

  @@index([status, createdAt(sort: Desc)])
  @@map("live_pdv_sessions")
}

/// LEGENDA DA LIVE — sequência de produtos com ATALHO curto (01, 02, ...).
/// A equipe monta e VALIDA antes da transmissão (mesma rotina searchGrade da
/// live); durante a live o operador digita só o atalho e o searchGrade
/// converte pra referência completa antes da busca normal.
model LivePdvAtalho {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  atalho    String   // código curto normalizado (trim + UPPER) — único por sessão
  refCode   String   @map("ref_code")  // referência COMPLETA validada (o termo que o operador digitaria)
  descricao String?  // snapshot da descrição na validação (exibição na lista)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session   LivePdvSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, atalho])
  @@index([sessionId, position])
  @@map("live_pdv_atalhos")
}

model LivePdvCart {
  id                String   @id @default(uuid())
  sessionId         String   @map("session_id")
  cartNumber        Int?     @map("cart_number")         // nº sequencial da comanda por sessão (busca por número)
  customerId        String?  @map("customer_id")        // FK lógico p/ Customer (sem relação p/ não tocar Customer)
  customerName      String   @map("customer_name")
  customerPhone     String   @map("customer_phone")
  customerInstagram String?  @map("customer_instagram")
  customerCpf       String?  @map("customer_cpf")
  customerEmail     String?  @map("customer_email")
  customerCep       String?  @map("customer_cep")
  // Endereço de entrega (capturado no ato do PIX; CEP puxa via ViaCEP).
  customerEndereco    String? @map("customer_endereco")     // logradouro
  customerNumero      String? @map("customer_numero")
  customerComplemento String? @map("customer_complemento")
  customerBairro      String? @map("customer_bairro")
  customerCidade      String? @map("customer_cidade")
  customerUf          String? @map("customer_uf")
  // Código curto do link público de pagamento (/p/<code>) — 8 chars aleatórios.
  // Substitui o UUID gigante no link que a cliente recebe no WhatsApp/Direct.
  payCode           String?  @unique @map("pay_code")
  // open | awaiting_payment | paid | separating | shipped | delivered | cancelled
  status            String   @default("open")
  subtotalCents     Int      @default(0) @map("subtotal_cents")
  freteCents        Int      @default(0) @map("frete_cents")
  totalCents        Int      @default(0) @map("total_cents")
  paymentMethod     String?  @map("payment_method")     // pix
  pagarmeOrderId    String?  @map("pagarme_order_id")
  qrCodeText        String?  @map("qr_code_text")        @db.Text
  qrCodeImageUrl    String?  @map("qr_code_image_url")   @db.Text
  paymentExpiresAt  DateTime? @map("payment_expires_at")
  paidAt            DateTime? @map("paid_at")
  // Quando a DM automática de cobrança (ManyChat) foi enviada — a cobrança em
  // massa PULA quem já recebeu (não repete DM); o botão individual reenvia.
  dmSentAt          DateTime? @map("dm_sent_at")
  // COBRANÇA AUTOMÁTICA POR WHATSAPP (11/07): carrinho parado → template
  // individual com o link exato via ManyChat API. 1 envio por carrinho;
  // tentativas limita retry em falha (não vira spam de erro).
  cobrancaWhatsEnviadaAt  DateTime? @map("cobranca_whats_enviada_at")
  cobrancaWhatsTentativas Int       @default(0) @map("cobranca_whats_tentativas")
  // RETIRADA EM LOJA (igual ao site): frete zero, prazo de até 7 dias úteis.
  // A cliente escolhe a loja no checkout; endereço deixa de ser obrigatório.
  isPickup          Boolean  @default(false) @map("is_pickup")
  pickupStoreCode   String?  @map("pickup_store_code")
  pickupStoreName   String?  @map("pickup_store_name")
  // TRILHO DO SITE (12/07): ao liberar a separação, a venda da live vira um
  // Order normal (source='live') e segue o fluxo do site (pick-orders, bip,
  // baixa, envio). orderId aponta pro Order gerado; o cart vira só o registro
  // da venda na live (cobrança/pagamento) + espelho de status.
  orderId           String?  @unique @map("order_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  session           LivePdvSession @relation(fields: [sessionId], references: [id])
  items             LivePdvItem[]

  @@unique([sessionId, cartNumber])
  @@index([sessionId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("live_pdv_carts")
}

model LivePdvItem {
  id                String   @id @default(uuid())
  cartId            String   @map("cart_id")
  sessionId         String   @map("session_id")
  refCode           String   @map("ref_code")
  itemKey           String   @map("item_key")           // REF|COR|TAM normalizado — chave de reserva
  codigoBipado      String?  @map("codigo_bipado")       // CODIGO Giga resolvido (baixa de estoque sem ambiguidade)
  descricao         String?
  cor               String?
  tamanho           String?
  qty               Int      @default(1)
  priceCents        Int      @map("price_cents")          // preço efetivo cobrado (promo da live se houver)
  basePriceCents    Int      @default(0) @map("base_price_cents") // preço cheio (sem promo) — base do custo e do "de/por"
  custoCents        Int      @map("custo_cents")         // basePriceCents / 2.5 (valor de custo p/ conciliação)
  originStoreCode   String   @map("origin_store_code")
  originStoreName   String   @map("origin_store_name")
  originManual      Boolean  @default(false) @map("origin_manual")  // supervisor trocou a loja manualmente
  // reserved | paid | separating | shipped | delivered | cancelled | expired
  status            String   @default("reserved")
  reservedAt        DateTime @default(now()) @map("reserved_at")
  expiresAt         DateTime @map("expires_at")
  paidAt            DateTime? @map("paid_at")
  separatedAt       DateTime? @map("separated_at")
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  trackingCode      String?  @map("tracking_code")
  transferOrderId   String?  @map("transfer_order_id")   // transferência interna gerada no despacho
  obligationId      String?  @map("obligation_id")        // obrigação intercompany gerada
  cancelledAt       DateTime? @map("cancelled_at")
  cancelReason      String?  @map("cancel_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  cart              LivePdvCart    @relation(fields: [cartId], references: [id])
  session           LivePdvSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, status])
  @@index([itemKey, status])
  @@index([originStoreCode, status])
  @@index([cartId])
  @@map("live_pdv_items")
}

// Preço promocional da live — definido pela atendente em tempo real, por
// produto (REF) dentro de uma sessão. Vale pra novos itens e atualiza os
// itens ainda RESERVADOS (não pagos). priceCents=preço promo em centavos.
model LivePdvPromo {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  refCode         String   @map("ref_code")        // REF normalizada (uppercase)
  priceCents      Int      @map("price_cents")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, refCode])
  @@map("live_pdv_promos")
}

// Vínculo @ do Instagram → ID de assinante do ManyChat, alimentado em tempo
// real pelo webhook público (automação "External Request" do ManyChat) e
// também pelo importador de CSV. A cobrança automática da live resolve o ID
// daqui quando a cliente ainda não tem Customer.manychatSubscriberId — cobre
// carrinho criado na mão pela apresentadora (cliente nunca clicou no link).
model LiveManychatSubscriber {
  id           String   @id @default(uuid())
  igUsername   String   @unique @map("ig_username") // sem @, lowercase
  subscriberId String   @map("subscriber_id")
  name         String?
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("live_manychat_subscribers")
}

// ─────────────────────────────────────────────────────────────────────────
// ESPELHO (ghost) do Giga — tabelas sincronizadas de hora em hora pelo
// GigaMirrorService. A conta corrente LÊ DAQUI (Postgres), nunca do Giga ao
// vivo → instantâneo, sem circuit-breaker, sem blip. O único ponto que fala
// com o Giga é o sync; se ele tropeça, tenta no próximo ciclo e a tela nem vê.
// ─────────────────────────────────────────────────────────────────────────

// Transferências agregadas por (origem, destino, documento, dia) — exatamente
// o grão que a cascata da conta corrente consome. totalPreco = soma de venda.
model GigaTransferencia {
  id         String   @id @default(cuid())
  ljOrigem   String   @map("lj_origem")
  ljDestino  String   @map("lj_destino")
  controle   String
  data       DateTime @db.Date
  qty        Int
  totalPreco Float    @map("total_preco")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@index([data])
  @@index([ljOrigem, ljDestino])
  @@map("giga_transferencia")
}

// Venda bruta por (loja, dia), já líquida de MARCADO='SIM'. Royalties somam por
// mês a partir daqui.
model GigaCaixaDiario {
  id       String   @id @default(cuid())
  loja     String
  data     DateTime @db.Date
  bruto    Float
  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([data])
  @@index([loja])
  @@map("giga_caixa_diario")
}

// Estado do sync (1 linha por tabela): última vez OK, erro, nº de linhas.
model GigaMirrorState {
  id         String    @id @default(cuid())
  tabela     String    @unique
  lastSyncAt DateTime? @map("last_sync_at")
  lastOkAt   DateTime? @map("last_ok_at")
  lastError  String?   @map("last_error")
  rows       Int       @default(0)
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("giga_mirror_state")
}

// Itens (peças/SKU) de cada transferência — o nível mais fundo da cascata.
// Grão: (origem, destino, documento, CODIGO, dia). Carregado sob demanda quando
// o usuário abre uma transferência específica (não vai no payload do extrato).
model GigaTransferenciaItem {
  id         String   @id @default(cuid())
  ljOrigem   String   @map("lj_origem")
  ljDestino  String   @map("lj_destino")
  controle   String
  codigo     String
  descricao  String?
  data       DateTime @db.Date
  qty        Int
  totalPreco Float    @map("total_preco")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@index([controle])
  @@index([data])
  @@map("giga_transferencia_item")
}

// Catálogo de produtos do Giga (espelho). Grão: 1 linha por CODIGO (SKU).
// Sincronizado pelo GigaMirrorService (no máx. a cada ~6h — catálogo muda devagar).
model GigaProduto {
  id        String   @id @default(cuid())
  codigo    String
  ref       String?
  descricao String?
  cor       String?
  tamanho   String?
  grupo     String?
  ncm       String?
  vendaUn   Float?   @map("venda_un")
  syncedAt  DateTime @default(now()) @map("synced_at")

  @@index([codigo])
  @@index([ref])
  @@map("giga_produto")
}

// Espelho do ESTOQUE do Giga por loja (CODIGO x LOJA). Usado como FALLBACK na
// Live quando o Giga ao vivo cai — nunca como fonte primária (estoque exato é
// sempre o ao vivo). Sync de hora em hora (full replace).
model GigaEstoque {
  id       String   @id @default(cuid())
  codigo   String
  loja     String
  estoque  Int
  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([codigo])
  @@map("giga_estoque")
}

/// Classificação BÁSICO/MODA por REFERÊNCIA (modelo). Owned 100% pelo Flow —
/// vive no Postgres e sobrevive aos syncs do ERP (que truncam wincred_produtos).
/// NÃO altera nada no Giga/Wincred ao vivo. Cruzada com o catálogo do ERP por REF.
///
/// Granularidade = REF (não SKU): básico/moda é característica do modelo, então
/// uma REF classificada vale pra todas as suas cores/tamanhos.
///
/// ref = REF do ERP normalizada (TRIM + UPPER). Produto SEM registro aqui =
/// tipoProduto 0 (MODA) e NÃO revisado, conforme a regra da tela.
model ProductClassification {
  ref                   String   @id @db.VarChar(20)
  tipoProduto           Int      @default(0) @map("tipo_produto") // 0=MODA, 1=BASICO
  classificacaoRevisada Boolean  @default(false) @map("classificacao_revisada")
  updatedBy             String?  @map("updated_by")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([tipoProduto])
  @@index([classificacaoRevisada])
  @@map("product_classification")
}

/// OperadorPin — PIN pessoal de liberação no PDV, por PESSOA (CPF), global (vale
/// em qualquer loja). Substitui a "senha compartilhada de nível" pelo PIN de cada
/// funcionária, mantendo a hierarquia (nivel) — e passa a saber QUEM autorizou.
/// A senha de nível compartilhada (env/AppConfig) segue como mestra de emergência.
/// O hash é sha256 com salt por linha (mesmo padrão do auth-levels.util); a
/// unicidade do PIN é garantida no service (não dá pra impor por índice com salt).
model OperadorPin {
  id        String   @id @default(cuid())
  cpf       String   @unique @db.VarChar(14)
  nome      String   @db.VarChar(120)
  nivel     String   @db.VarChar(20) // CAIXA | SUPERVISOR | GERENTE | MASTER | SUPREMA
  pinSalt   String   @map("pin_salt")
  pinHash   String   @map("pin_hash")
  ativo     Boolean  @default(true)
  // Loja de origem — escopo de visualização (gerente vê só as da sua loja).
  storeCode String?  @map("store_code") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ativo])
  @@index([storeCode])
  @@map("operador_pin")
}

/// ═══════════════ CONTAS A PAGAR (100% Flow — GIGA congelado) ═══════════════
/// Decisões do dono 11/07/2026 + dossiê docs/GIGA-CONTAS-DESCOBERTA.md.
/// GigaPagar = espelho RAW fiel da tabela `pagar` (só pra migração/conferência
/// do congelamento — NUNCA é fonte de tela). ContaPagar = o modelo novo.

model GigaPagar {
  registro Int      @id // pagar.REGISTRO (PK do GIGA)
  pnum     String?  @db.VarChar(30)
  pesp     String?  @db.VarChar(10)
  pser     String?  @db.VarChar(5)
  pfav     Int?
  pemi     DateTime? @db.Date
  pban     String?  @db.VarChar(20)
  pval     Decimal? @db.Decimal(10, 2)
  pven     DateTime? @db.Date
  paga     DateTime? @db.Date
  pjur     Decimal? @db.Decimal(10, 2)
  pdes     Decimal? @db.Decimal(10, 2)
  pobs     String?  @db.VarChar(50)
  nnota    String?  @db.VarChar(10)
  ncheque  String?  @db.VarChar(12)
  pend     String?  @db.VarChar(3)
  loja     String?  @db.VarChar(2)
  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([loja])
  @@index([pven])
  @@index([pesp])
  @@map("giga_pagar")
}

/// Catálogo de espécies — editável na tela. Semente = 11 do GIGA + as variantes
/// promovidas (CHEQUE, PROMISSORIA, CARNE, SEM ESPECIE) + as novas de
/// funcionárias (SALARIO, COMISSAO). `restrita` = só perfis autorizados veem
/// contas dessa espécie (RH/SALARIO/VALE/COMISSAO — salário é dado sensível).
model EspecieConta {
  id        String   @id @default(cuid())
  nome      String   @unique @db.VarChar(30)
  restrita  Boolean  @default(false)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  contas ContaPagar[]

  @@map("especie_conta")
}

/// A conta a pagar do Flow. Migrada do GIGA (gigaRegistro preenchido) ou
/// nascida aqui. Soft delete (deletedAt/deletedBy) — nada some de verdade.
/// Beneficiário: FORNECEDOR (fornecedorGigaCodigo/nome) OU FUNCIONARIA
/// (sellerId/CPF do RH). Parcelas REAIS via grupoParcelaId + parcelaNum/Total.
model ContaPagar {
  id       String @id @default(cuid())
  numero   Int    @unique @default(autoincrement())
  lojaCode String @map("loja_code") @db.VarChar(4)

  beneficiarioTipo    String  @default("fornecedor") @map("beneficiario_tipo") @db.VarChar(12) // fornecedor | funcionaria
  fornecedorGigaCodigo Int?   @map("fornecedor_giga_codigo")
  fornecedorNome      String? @map("fornecedor_nome") @db.VarChar(120)
  sellerId            String? @map("seller_id")
  sellerNome          String? @map("seller_nome") @db.VarChar(120)
  sellerCpf           String? @map("seller_cpf") @db.VarChar(14)

  especieId       String? @map("especie_id")
  especie         EspecieConta? @relation(fields: [especieId], references: [id])
  especieOriginal String? @map("especie_original") @db.VarChar(10) // PESP cru do GIGA

  notaFiscal String? @map("nota_fiscal") @db.VarChar(40)
  banco      String? @db.VarChar(40)
  cheque     String? @db.VarChar(20)
  emissao    DateTime? @db.Date
  vencimento DateTime  @db.Date
  valorCents Int       @map("valor_cents")

  // Baixa (P3 do dono: juros e desconto SÃO preenchidos no pagamento)
  pagamento      DateTime? @db.Date
  jurosCents     Int       @default(0) @map("juros_cents")
  descontoCents  Int       @default(0) @map("desconto_cents")
  pagoPor        String?   @map("pago_por") @db.VarChar(80)

  emMaos         Boolean @default(false) @map("em_maos")
  emMaosOriginal String? @map("em_maos_original") @db.VarChar(3) // PEND cru do GIGA
  observacao     String? @db.VarChar(200)

  parcelaNum     Int?    @map("parcela_num")
  parcelaTotal   Int?    @map("parcela_total")
  grupoParcelaId String? @map("grupo_parcela_id")

  status String @default("aberta") @db.VarChar(12) // aberta | paga | cancelada

  // Migração/qualidade (dossiê §4)
  gigaRegistro    Int?    @unique @map("giga_registro")
  favorecidoOrfao Boolean @default(false) @map("favorecido_orfao")
  dataSuspeita    Boolean @default(false) @map("data_suspeita")

  createdBy String?   @map("created_by") @db.VarChar(80)
  updatedBy String?   @map("updated_by") @db.VarChar(80)
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  logs ContaPagarLog[]

  @@index([lojaCode, vencimento])
  @@index([status, vencimento])
  @@index([especieId])
  @@index([sellerId])
  @@index([grupoParcelaId])
  @@index([fornecedorNome])
  @@index([deletedAt])
  @@map("conta_pagar")
}

/// Auditoria POR CAMPO de toda alteração (quem, o quê, antes → depois).
model ContaPagarLog {
  id         String   @id @default(cuid())
  contaId    String   @map("conta_id")
  conta      ContaPagar @relation(fields: [contaId], references: [id])
  campo      String   @db.VarChar(40)
  valorAntigo String? @map("valor_antigo") @db.VarChar(300)
  valorNovo   String? @map("valor_novo") @db.VarChar(300)
  usuario    String?  @db.VarChar(80)
  origem     String   @default("tela") @db.VarChar(20) // tela | migracao | sistema
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([contaId])
  @@index([createdAt])
  @@map("conta_pagar_log")
}

/// Associação Fornecedor(GIGA) → Funcionária (decisão do dono 11/07): os
/// ~440 "fornecedores" que são PESSOAS (folha RH/VALE de 20 anos) viram
/// beneficiário FUNCIONÁRIA nas contas e somem do autocomplete de
/// fornecedores. Persistente (o espelho wincred_fornecedores é truncado a
/// cada sync — flag lá se perderia). naoEhPessoa=true = descartado da
/// conciliação (ex.: CONTABILIDADE). Reversível (desfazer apaga a linha).
model ContaPagarAssociacao {
  id                   String   @id @default(cuid())
  fornecedorGigaCodigo Int      @unique @map("fornecedor_giga_codigo")
  fornecedorNome       String?  @map("fornecedor_nome") @db.VarChar(120)
  sellerId             String?  @map("seller_id")
  sellerNome           String?  @map("seller_nome") @db.VarChar(120)
  naoEhPessoa          Boolean  @default(false) @map("nao_eh_pessoa")
  contasConvertidas    Int      @default(0) @map("contas_convertidas")
  criadoPor            String?  @map("criado_por") @db.VarChar(80)
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@map("conta_pagar_associacao")
}
