{
  "name": "lurds-order-one-desktop",
  "version": "1.0.9",
  "description": "LURDS ORDER ONE — app de loja (tray + auto-start + impressao silenciosa)",
  "main": "src/main.js",
  "author": "LURDS",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --app-url=http://localhost:3000/minha-loja",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.lurds.orderone.desktop",
    "productName": "LURDS ORDER ONE",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "LURDS-ORDER-ONE-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LURDS ORDER ONE",
      "runAfterFinish": true,
      "warningsAsErrors": false,
      "include": "build/installer.nsh"
    },
    "extraResources": [
      {
        "from": "build/",
        "to": "build/",
        "filter": ["icon.ico", "icon-tray.png", "icon-ponto.ico"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "trissutto",
        "repo": "flowops-lite",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.0"
  }
}
